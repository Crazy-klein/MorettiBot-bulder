<div class="glass p-8 rounded-[2.5rem] border border-white/5 hover:border-gold/30 hover:-translate-y-2 transition-all duration-500 group flex flex-col h-full shadow-[0_8px_32px_rgba(0,0,0,0.3)] relative overflow-hidden">
    <!-- Overlay Glow -->
    <div class="absolute -top-10 -right-10 w-24 h-24 bg-gold/5 rounded-full blur-2xl group-hover:bg-gold/10 transition-all duration-700"></div>

    <div class="flex items-start justify-between mb-8">
        <div class="flex items-center space-x-4">
            <div class="w-14 h-14 rounded-2xl bg-white/5 flex items-center justify-center text-gray-500 group-hover:text-gold group-hover:bg-gold/10 group-hover:scale-110 transition-all duration-500 border border-white/5 group-hover:border-gold/20">
                <i data-lucide="cpu" class="w-7 h-7"></i>
            </div>
            <div>
                <h4 class="text-white font-black group-hover:text-gold transition-colors tracking-tight text-lg"><%= bot.name %></h4>
                <div class="flex items-center mt-1">
                    <span class="text-[9px] text-gray-500 font-black uppercase tracking-widest bg-white/5 px-2 py-0.5 rounded-md"><%= bot.type %></span>
                </div>
            </div>
        </div>
        <div class="flex flex-col items-end">
            <span class="px-3 py-1 rounded-full text-[9px] font-black uppercase tracking-widest border border-white/5 transition-all"
                :class="'<%= bot.status === 'running' ? 'bg-green-500/10 text-green-500 border-green-500/20' : 
                       (bot.status === 'generated' ? 'bg-gold/10 text-gold border-gold/20' : 
                       'bg-white/5 text-gray-600 border-white/10') %>'">
                <%= bot.status === 'running' ? 'Actif' : (bot.status === 'generated' ? 'Prêt' : 'Draft') %>
            </span>
        </div>
    </div>

    <!-- Details -->
    <div class="space-y-4 mb-10 flex-1 px-1">
        <div class="flex items-center justify-between">
            <span class="text-[10px] font-black text-gray-500 uppercase tracking-widest">Configuration</span>
            <span class="text-[10px] font-bold text-white bg-white/5 px-2.5 py-1 rounded-lg border border-white/5">Prefix: <span class="text-gold font-mono"><%= bot.prefix %></span></span>
        </div>
        <div class="flex items-center justify-between">
            <span class="text-[10px] font-black text-gray-500 uppercase tracking-widest">Initialisé le</span>
            <span class="text-[10px] font-bold text-gray-400 capitalize"><%= new Date(bot.createdAt).toLocaleDateString('fr-FR', {day: '2-digit', month: 'short', year: 'numeric'}) %></span>
        </div>
        <!-- Progress decor -->
        <div class="pt-4">
            <div class="w-full h-1 bg-white/5 rounded-full overflow-hidden">
                <div class="h-full bg-gold/30 rounded-full" style="width: 100%"></div>
            </div>
        </div>
    </div>

    <!-- Actions Area -->
    <div class="grid grid-cols-2 gap-3 mt-auto relative z-10">
        <% if (bot.status === 'running') { %>
            <a href="/bots/<%= bot.id %>/session" class="col-span-1 bg-gold/10 text-gold font-black py-4 rounded-2xl text-[10px] uppercase tracking-widest text-center border border-gold/10 hover:bg-gold/20 hover:scale-[1.03] active:scale-95 transition-all">
                Console
            </a>
            <form action="/bots/<%= bot.id %>/stop-session" method="POST" class="col-span-1">
                <button type="submit" class="w-full bg-red-500/10 text-red-400 font-black py-4 rounded-2xl text-[10px] uppercase tracking-widest border border-red-500/10 hover:bg-red-500/20 hover:scale-[1.03] active:scale-95 transition-all">
                    Shutdown
                </button>
            </form>
        <% } else { %>
            <form action="/bots/<%= bot.id %>/start-session" method="POST" class="col-span-2">
                <button type="submit" class="w-full bg-gold text-dark font-black py-4 rounded-2xl text-[10px] uppercase tracking-widest hover:scale-[1.02] active:scale-95 transition-all shadow-lg shadow-gold/10 animate-pulse-gold">
                    Déployer l'Instance
                </button>
            </form>
            <div class="col-span-2 grid grid-cols-2 gap-3 pt-1">
                <a href="/bots/<%= bot.id %>/backups" class="col-span-1 glass text-gray-400 font-black py-3.5 rounded-2xl text-[9px] uppercase tracking-widest text-center hover:text-white hover:border-white/20 transition-all flex items-center justify-center">
                    <i data-lucide="archive" class="w-3 h-3 mr-2"></i> Backups
                </a>
                <form action="/bots/<%= bot.id %>/delete" method="POST" class="col-span-1" onsubmit="return confirm('Confirmer la suppression de cette architecture ?')">
                    <button type="submit" class="w-full glass text-gray-600 font-black py-3.5 rounded-2xl text-[9px] uppercase tracking-widest hover:text-red-500 hover:border-red-500/20 transition-all flex items-center justify-center">
                        <i data-lucide="trash-2" class="w-3 h-3 mr-2"></i> Purger
                    </button>
                </form>
            </div>
        <% } %>
    </div>
</div>
