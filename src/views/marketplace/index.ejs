<div class="space-y-12">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 px-2">
        <div>
            <div class="flex items-center space-x-3 mb-3">
                <div class="w-10 h-10 glass rounded-xl flex items-center justify-center text-gold">
                    <i data-lucide="shopping-bag" class="w-5 h-5"></i>
                </div>
                <span class="text-[10px] font-black text-gray-500 uppercase tracking-[0.3em]">Boutique d'Élite</span>
            </div>
            <h2 class="text-4xl font-black text-white tracking-tight">Marketplace des <span class="gold-gradient-text italic">Architectes</span></h2>
            <p class="text-gray-500 font-medium mt-1">Acquérez des instances pré-configurées ou partagez votre génie avec la communauté.</p>
        </div>
        
        <a href="/marketplace/submit" class="bg-gold text-dark px-10 py-5 rounded-[2rem] font-black text-[10px] uppercase tracking-widest hover:scale-105 active:scale-95 transition-all shadow-[0_20px_60px_rgba(212,163,115,0.3)] border border-gold-light/20 flex items-center group">
            <i data-lucide="plus" class="w-4 h-4 mr-2 group-hover:rotate-90 transition-transform"></i>
            Soumettre une création
        </a>
    </div>

    <!-- Marketplace Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
        <% if (bots.length === 0) { %>
            <div class="col-span-full py-40 text-center glass rounded-[4rem] border border-white/5 border-dashed">
                <div class="w-24 h-24 bg-white/5 rounded-full flex items-center justify-center mx-auto mb-8 text-gray-800">
                    <i data-lucide="package-search" class="w-12 h-12"></i>
                </div>
                <h4 class="text-2xl font-black text-white mb-2">Architectes encore discrets</h4>
                <p class="text-gray-600 font-medium">Le marketplace est en attente de ses premières transmissions certifiées.</p>
            </div>
        <% } else { %>
            <% bots.forEach(bot => { %>
                <a href="/marketplace/<%= bot.id %>" class="glass p-10 rounded-[3.5rem] border border-white/5 hover:border-gold/30 hover:-translate-y-3 transition-all duration-500 group relative overflow-hidden flex flex-col h-full shadow-[0_30px_100px_rgba(0,0,0,0.5)]">
                    <!-- Overlay Glow -->
                    <div class="absolute -top-10 -right-10 w-40 h-40 bg-gold/5 rounded-full blur-3xl group-hover:bg-gold/10 transition-all duration-1000"></div>

                    <div class="flex items-center space-x-6 mb-8 relative z-10">
                        <div class="w-20 h-20 rounded-[2.2rem] glass p-2 border border-white/5 overflow-hidden group-hover:border-gold/20 transition-all shadow-inner">
                            <img src="<%= bot.logo || '/assets/default-bot.png' %>" alt="<%= bot.name %>" class="w-full h-full object-cover rounded-[1.8rem] filter group-hover:brightness-110 transition-all">
                        </div>
                        <div>
                            <h3 class="text-xl font-black text-white group-hover:text-gold transition-colors tracking-tight"><%= bot.name %></h3>
                            <div class="flex items-center space-x-2 mt-1">
                                <span class="px-2.5 py-1 glass rounded-lg text-[9px] font-black uppercase tracking-widest text-gold bg-gold/5 border border-gold/10"><%= bot.price === 0 ? 'Gratuit' : bot.price + ' FCFA' %></span>
                            </div>
                        </div>
                    </div>

                    <p class="text-[11px] text-gray-500 font-medium leading-relaxed mb-10 line-clamp-3 relative z-10"><%= bot.description %></p>

                    <div class="mt-auto space-y-6 relative z-10">
                        <div class="w-full h-px bg-white/5"></div>
                        <div class="flex items-center justify-between">
                            <div class="flex items-center space-x-6">
                                <div class="flex flex-col">
                                    <span class="text-[8px] font-black text-gray-700 uppercase tracking-widest mb-1">Commandes</span>
                                    <span class="text-[12px] font-black text-white"><%= bot.commandCount %>+</span>
                                </div>
                                <div class="w-px h-8 bg-white/5"></div>
                                <div class="flex flex-col font-black text-gold">
                                    <div class="flex items-center">
                                        <% for(let i=0; i<5; i++) { %>
                                            <i data-lucide="star" class="w-2.5 h-2.5 <%= i < Math.round(bot.rating) ? 'fill-gold' : 'text-gray-800' %>"></i>
                                        <% } %>
                                    </div>
                                    <span class="text-[8px] uppercase tracking-widest mt-1"><%= bot.reviewCount %> avis</span>
                                </div>
                            </div>
                            <div class="w-12 h-12 glass rounded-2xl flex items-center justify-center text-gold group-hover:bg-gold group-hover:text-dark transition-all shadow-lg border border-white/5">
                                <i data-lucide="arrow-right" class="w-5 h-5 group-hover:translate-x-1 transition-transform"></i>
                            </div>
                        </div>
                    </div>
                </a>
            <% }) %>
        <% } %>
    </div>
</div>
