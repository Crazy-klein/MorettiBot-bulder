<div class="max-w-md mx-auto py-10">
    <div class="bg-dark-card border border-white/5 p-10 rounded-[2.5rem] shadow-2xl">
        <div class="text-center mb-10">
            <h2 class="text-3xl font-bold text-white mb-2">Bon retour !</h2>
            <p class="text-gray-500">Connectez-vous pour gérer vos bots</p>
        </div>

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="bg-red-400/10 border border-red-400/20 text-red-400 p-4 rounded-2xl mb-6 text-sm flex items-center">
                <i data-lucide="alert-circle" class="w-4 h-4 mr-2"></i>
                <%= error %>
            </div>
        <% } %>

        <form action="/login" method="POST" class="space-y-6">
            <div class="space-y-2">
                <label class="text-sm font-medium text-gray-400 ml-1">Email</label>
                <div class="relative">
                    <i data-lucide="mail" class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-600"></i>
                    <input type="email" name="email" required class="w-full bg-[#121417] border border-white/10 rounded-2xl py-4 pl-12 pr-4 text-white focus:border-gold outline-none transition-all" placeholder="votre@email.com">
                </div>
            </div>

            <div class="space-y-2">
                <div class="flex justify-between items-center ml-1">
                    <label class="text-sm font-medium text-gray-400">Mot de passe</label>
                    <a href="/forgot-password" class="text-xs text-gold hover:underline">Oublié ?</a>
                </div>
                <div class="relative">
                    <i data-lucide="lock" class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-600"></i>
                    <input type="password" name="password" required class="w-full bg-[#121417] border border-white/10 rounded-2xl py-4 pl-12 pr-4 text-white focus:border-gold outline-none transition-all" placeholder="••••••••">
                </div>
            </div>

            <button type="submit" class="w-full bg-gold text-dark font-bold py-4 rounded-2xl hover:scale-[1.02] active:scale-[0.98] transition-all shadow-xl shadow-gold/20 mt-4">
                Se connecter
            </button>
        </form>

        <p class="text-center text-gray-500 text-sm mt-8">
            Pas encore de compte ? <a href="/register" class="text-gold font-semibold hover:underline">Inscrivez-vous</a>
        </p>
    </div>
</div>
