<div class="max-w-md mx-auto">
    <div class="glass p-10 rounded-[2.5rem] border border-white/5 shadow-[0_20px_50px_rgba(0,0,0,0.5)] relative overflow-hidden group">
        <!-- Decor -->
        <div class="absolute -top-20 -right-20 w-40 h-40 bg-gold/10 rounded-full blur-3xl"></div>
        
        <div class="relative z-10 space-y-8">
            <div class="text-center">
                <div class="w-16 h-16 bg-gold/20 rounded-2xl flex items-center justify-center text-gold mx-auto mb-6 border border-gold/20 shadow-lg">
                    <i data-lucide="key-round" class="w-8 h-8"></i>
                </div>
                <h2 class="text-3xl font-black text-white tracking-tight">Récupération</h2>
                <p class="text-gray-500 text-[10px] font-black uppercase tracking-widest mt-2">Protocole de réinitialisation</p>
            </div>

            <% if (typeof message !== 'undefined' && message) { %>
                <div class="glass bg-green-500/10 border border-green-500/20 text-green-500 px-6 py-4 rounded-2xl text-sm font-bold flex items-center">
                    <i data-lucide="mail-check" class="w-5 h-5 mr-3"></i>
                    <%= message %>
                </div>
            <% } %>

            <% if (typeof error !== 'undefined' && error) { %>
                <div class="glass bg-red-500/10 border border-red-500/20 text-red-500 px-6 py-4 rounded-2xl text-sm font-bold flex items-center animate-shake">
                    <i data-lucide="shield-alert" class="w-5 h-5 mr-3"></i>
                    <%= error %>
                </div>
            <% } %>

            <p class="text-gray-500 text-sm text-center font-medium leading-relaxed">
                Entrez votre adresse email de privilège pour recevoir une clé de restauration temporaire.
            </p>

            <form action="/forgot-password" method="POST" class="space-y-6">
                <div class="space-y-2">
                    <label class="text-[10px] font-black text-gray-500 uppercase tracking-widest ml-1">Adresse Email</label>
                    <div class="relative">
                        <i data-lucide="mail" class="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400"></i>
                        <input type="email" name="email" required class="w-full pl-12 pr-4 py-4 bg-black/20 border border-white/5 rounded-2xl text-white focus:outline-none transition-all placeholder:text-gray-700 font-medium" placeholder="votre@email.com">
                    </div>
                </div>

                <button type="submit" class="w-full bg-gold text-dark font-black py-5 rounded-2xl hover:scale-[1.02] active:scale-95 transition-all shadow-xl shadow-gold/20 uppercase text-xs tracking-widest border border-gold-light/20">
                    Envoyer le protocole
                </button>
            </form>

            <div class="text-center pt-4">
                <a href="/login" class="text-gray-500 text-[10px] font-black uppercase tracking-widest hover:text-white transition-colors flex items-center justify-center group">
                    <i data-lucide="arrow-left" class="w-3 h-3 mr-2 group-hover:-translate-x-1 transition-transform"></i>
                    Retour au terminal
                </a>
            </div>
        </div>
    </div>
</div>
