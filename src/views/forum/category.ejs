<div class="space-y-12">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 px-2">
        <div class="flex items-center space-x-6">
            <a href="/forum" class="w-12 h-12 glass rounded-2xl flex items-center justify-center text-gray-400 hover:text-gold transition-all">
                <i data-lucide="arrow-left" class="w-6 h-6"></i>
            </a>
            <div>
                <h2 class="text-4xl font-black text-white tracking-tight leading-none uppercase tracking-tighter"><span class="text-gold/50">Flux:</span> <%= category.name %></h2>
                <p class="text-gray-500 font-medium mt-2"><%= category.description %></p>
            </div>
        </div>

        <a href="/forum/topic/new/<%= category.id %>" class="bg-gold text-dark px-10 py-5 rounded-[2rem] font-black text-[10px] uppercase tracking-widest hover:scale-105 active:scale-95 transition-all shadow-[0_20px_60px_rgba(212,163,115,0.3)] border border-gold-light/20 flex items-center">
            <i data-lucide="plus" class="w-4 h-4 mr-2"></i>
            Ouvrir un Sujet
        </a>
    </div>

    <!-- Topics List -->
    <div class="glass rounded-[4rem] border border-white/5 overflow-hidden shadow-[0_40px_100px_rgba(0,0,0,0.5)]">
        <% if (topics.length === 0) { %>
            <div class="py-32 text-center">
                <div class="w-20 h-20 bg-white/5 rounded-full flex items-center justify-center mx-auto mb-6 text-gray-800">
                    <i data-lucide="inbox" class="w-10 h-10"></i>
                </div>
                <h4 class="text-xl font-bold text-white mb-2">Centre Silencieux</h4>
                <p class="text-gray-500">Initiez la première transmission neuronale dans cette catégorie.</p>
            </div>
        <% } else { %>
            <div class="divide-y divide-white/[0.03]">
                <% topics.forEach(topic => { %>
                    <a href="/forum/topic/<%= topic.id %>" class="flex items-center p-10 hover:bg-white/[0.01] transition-all group relative">
                        <% if (topic.isPinned) { %>
                            <div class="absolute left-0 top-0 bottom-0 w-1 bg-gold shadow-[0_0_15px_rgba(212,163,115,0.4)]"></div>
                        <% } %>

                        <div class="w-16 h-16 rounded-[1.5rem] bg-white/5 border border-white/5 flex items-center justify-center text-gray-600 group-hover:text-gold group-hover:bg-gold/10 group-hover:border-gold/20 transition-all duration-500 shrink-0">
                            <i data-lucide="<%= topic.isPinned ? 'pin' : (topic.isLocked ? 'lock' : 'message-square') %>" class="w-8 h-8"></i>
                        </div>

                        <div class="ml-10 flex-1">
                            <h4 class="text-xl font-black text-white group-hover:text-gold transition-all tracking-tight uppercase tracking-tighter mb-2">
                                <%= topic.title %>
                                <% if (topic.isPinned) { %> <span class="ml-3 text-[9px] font-black text-gold border border-gold/20 px-2 py-0.5 rounded-full bg-gold/5 uppercase tracking-widest">Épinglé</span> <% } %>
                            </h4>
                            <div class="flex items-center space-x-6">
                                <span class="text-[9px] font-black text-gray-700 uppercase tracking-widest">Architecte: @<%= topic.username %></span>
                                <div class="w-1 h-1 rounded-full bg-white/10"></div>
                                <span class="text-[9px] font-black text-gray-700 uppercase tracking-widest"><%= new Date(topic.createdAt).toLocaleString('fr-FR', {day: '2-digit', month: 'short'}) %></span>
                            </div>
                        </div>

                        <div class="flex items-center space-x-12 px-10">
                            <div class="text-right">
                                <p class="text-[14px] font-black text-white leading-none"><%= topic.replyCount %></p>
                                <p class="text-[8px] font-black text-gray-700 uppercase tracking-widest mt-1">Réponses</p>
                            </div>
                            <div class="text-right">
                                <p class="text-[14px] font-black text-white leading-none"><%= topic.views %></p>
                                <p class="text-[8px] font-black text-gray-700 uppercase tracking-widest mt-1">Impulsions</p>
                            </div>
                        </div>

                        <div class="w-12 h-12 glass rounded-2xl flex items-center justify-center text-gray-800 opacity-0 group-hover:opacity-100 group-hover:text-gold transition-all duration-700">
                            <i data-lucide="chevron-right" class="w-6 h-6"></i>
                        </div>
                    </a>
                <% }) %>
            </div>
        <% } %>
    </div>
</div>
