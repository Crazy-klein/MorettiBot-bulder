<div class="space-y-12">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 px-2">
        <div>
            <div class="flex items-center space-x-3 mb-3">
                <div class="w-10 h-10 glass rounded-xl flex items-center justify-center text-gold">
                    <i data-lucide="message-square" class="w-5 h-5"></i>
                </div>
                <span class="text-[10px] font-black text-gray-500 uppercase tracking-[0.3em]">Synapse Communautaire</span>
            </div>
            <h2 class="text-4xl font-black text-white tracking-tight">Le <span class="gold-gradient-text italic">Hangar</span> des Discussions</h2>
            <p class="text-gray-500 font-medium mt-1">Établissez des connexions neuronales avec d'autres architectes du réseau.</p>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
        <% categories.forEach(cat => { %>
            <a href="/forum/category/<%= cat.id %>" class="glass p-10 rounded-[3.5rem] border border-white/5 hover:border-gold/30 hover:bg-gold/[0.02] transition-all duration-500 group flex items-start space-x-8 shadow-[0_20px_60px_rgba(0,0,0,0.4)]">
                <div class="w-20 h-20 bg-white/5 rounded-[2.2rem] flex items-center justify-center text-gray-600 group-hover:bg-gold/10 group-hover:text-gold transition-all duration-500 border border-transparent group-hover:border-gold/20 shadow-inner group-hover:scale-110">
                    <i data-lucide="<%= cat.icon %>" class="w-10 h-10"></i>
                </div>
                <div class="flex-1">
                    <h3 class="text-2xl font-black text-white group-hover:text-gold transition-colors tracking-tight mb-2 uppercase tracking-tighter"><%= cat.name %></h3>
                    <p class="text-[11px] text-gray-500 font-medium leading-relaxed mb-6"><%= cat.description %></p>
                    
                    <div class="flex items-center space-x-4">
                        <div class="flex items-center">
                            <i data-lucide="layers" class="w-3 h-3 text-gold/50 mr-2"></i>
                            <span class="text-[9px] font-black text-gray-600 uppercase tracking-widest">Sujets Actifs</span>
                        </div>
                        <div class="w-1 h-1 rounded-full bg-white/10"></div>
                        <div class="flex items-center">
                            <i data-lucide="activity" class="w-3 h-3 text-gold/50 mr-2"></i>
                            <span class="text-[9px] font-black text-gray-600 uppercase tracking-widest">Temps Réel</span>
                        </div>
                    </div>
                </div>
                <div class="w-12 h-12 glass rounded-2xl flex items-center justify-center text-gray-800 group-hover:text-gold transition-all duration-700">
                    <i data-lucide="chevron-right" class="w-6 h-6 group-hover:translate-x-1 transition-transform"></i>
                </div>
            </a>
        <% }) %>
    </div>

    <!-- Live support banner/CTA -->
    <div class="glass p-12 rounded-[4rem] border border-gold/10 relative overflow-hidden group shadow-2xl">
        <div class="absolute -top-40 -right-40 w-96 h-96 bg-gold/5 rounded-full blur-[100px] group-hover:bg-gold/10 transition-all duration-1000"></div>
        <div class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-8">
            <div class="max-w-xl">
                <h3 class="text-3xl font-black text-white tracking-tighter mb-3 uppercase">Architecture <span class="gold-gradient-text italic">Collaborative</span></h3>
                <p class="text-gray-500 font-medium leading-relaxed">Rejoignez le canal officiel de diffusion pour des mises à jour en millisecondes et un support prioritaire par les ingénieurs Kurona.</p>
            </div>
            <a href="https://wa.me/..." target="_blank" class="bg-gold text-dark px-12 py-5 rounded-[2rem] font-black text-[10px] uppercase tracking-widest hover:scale-105 active:scale-95 transition-all shadow-xl shadow-gold/20 border border-gold-light/20 flex items-center">
                <i data-lucide="zap" class="w-4 h-4 mr-3 animate-pulse"></i>
                Lien vers le Canal
            </a>
        </div>
    </div>
</div>
