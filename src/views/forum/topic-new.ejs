<div class="max-w-4xl mx-auto py-8">
    <div class="mb-12 px-2 flex items-center space-x-8">
        <a href="/forum/category/<%= categoryId %>" class="w-12 h-12 glass rounded-2xl flex items-center justify-center text-gray-400 hover:text-gold transition-all">
            <i data-lucide="arrow-left" class="w-6 h-6"></i>
        </a>
        <div>
            <div class="flex items-center space-x-3 mb-3">
                <div class="w-10 h-10 glass rounded-xl flex items-center justify-center text-gold">
                    <i data-lucide="pen-tool" class="w-5 h-5"></i>
                </div>
                <span class="text-[10px] font-black text-gray-500 uppercase tracking-[0.3em]">Ouverture de Flux</span>
            </div>
            <h2 class="text-4xl font-black text-white tracking-tight">Nouvelle <span class="gold-gradient-text italic">Discussion</span></h2>
        </div>
    </div>

    <form action="/forum/topic/new" method="POST" class="glass p-12 rounded-[4rem] border border-white/5 shadow-2x space-y-10">
        <input type="hidden" name="categoryId" value="<%= categoryId %>">
        
        <div class="space-y-4">
            <label class="text-[10px] font-black text-gray-500 uppercase tracking-widest ml-2">Titre du Sujet</label>
            <input type="text" name="title" required class="w-full bg-black/20 border border-white/5 rounded-2xl py-6 px-8 text-white text-2xl font-black tracking-tight focus:outline-none focus:border-gold transition-all placeholder:text-gray-800" placeholder="Entrez un titre percutant...">
        </div>

        <div class="space-y-4">
            <label class="text-[10px] font-black text-gray-500 uppercase tracking-widest ml-2">Contenu de la Transmission</label>
            <textarea name="content" required rows="8" class="w-full bg-black/20 border border-white/5 rounded-[2.5rem] py-6 px-8 text-white font-medium leading-relaxed focus:outline-none focus:border-gold transition-all resize-none placeholder:text-gray-800" placeholder="Détaillez votre pensée ou votre question technique..."></textarea>
        </div>

        <div class="pt-6 flex justify-end">
            <button type="submit" class="group relative bg-gold text-dark px-12 py-5 rounded-[2rem] font-black text-[10px] uppercase tracking-[0.3em] overflow-hidden hover:scale-105 active:scale-95 transition-all shadow-xl shadow-gold/20 border border-gold-light/20">
                <div class="absolute inset-0 bg-white/20 translate-y-full group-hover:translate-y-0 transition-transform duration-500"></div>
                <span class="relative z-10 flex items-center">
                    <i data-lucide="send" class="w-4 h-4 mr-3 group-hover:rotate-12 transition-transform"></i>
                    Diffuser le Sujet
                </span>
            </button>
        </div>
    </form>
</div>
