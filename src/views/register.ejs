<div class="max-w-md mx-auto">
    <div class="glass p-10 rounded-[2.5rem] border border-white/5 shadow-[0_20px_50px_rgba(0,0,0,0.5)] relative overflow-hidden group">
        <!-- Decor -->
        <div class="absolute -top-20 -left-20 w-40 h-40 bg-gold/10 rounded-full blur-3xl group-hover:bg-gold/20 transition-all duration-700"></div>

        <div class="relative z-10 space-y-8">
            <div class="text-center">
                <div class="w-16 h-16 bg-gold/20 rounded-2xl flex items-center justify-center text-gold mx-auto mb-6 border border-gold/20 shadow-lg">
                    <i data-lucide="sparkles" class="w-8 h-8"></i>
                </div>
                <h2 class="text-3xl font-black text-white tracking-tight">Rejoindre l'Elite</h2>
                <p class="text-gray-500 text-xs font-bold uppercase tracking-widest mt-2">Créez votre identité Kurona</p>
            </div>

            <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
                <div class="bg-red-500/10 border border-red-500/20 text-red-500 px-6 py-4 rounded-2xl text-sm font-bold space-y-1">
                    <% errors.forEach(error => { %>
                        <div class="flex items-center">
                            <i data-lucide="x-circle" class="w-4 h-4 mr-2"></i>
                            <%= typeof error === 'string' ? error : error.message %>
                        </div>
                    <% }) %>
                </div>
            <% } %>

            <form action="/register" method="POST" class="space-y-6">
                <div class="space-y-2">
                    <label class="text-[10px] font-black text-gray-500 uppercase tracking-widest ml-1">Nom d'utilisateur</label>
                    <div class="relative">
                        <i data-lucide="user" class="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-500"></i>
                        <input type="text" name="username" value="<%= data.username || '' %>" required class="w-full pl-12 pr-4 py-4 bg-black/20 border border-white/5 rounded-2xl text-white focus:outline-none transition-all placeholder:text-gray-700 font-medium" placeholder="Ex: KuronaExpert">
                    </div>
                </div>

                <div class="space-y-2">
                    <label class="text-[10px] font-black text-gray-500 uppercase tracking-widest ml-1">Adresse Email</label>
                    <div class="relative">
                        <i data-lucide="mail" class="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-500"></i>
                        <input type="email" name="email" value="<%= data.email || '' %>" required class="w-full pl-12 pr-4 py-4 bg-black/20 border border-white/5 rounded-2xl text-white focus:outline-none transition-all placeholder:text-gray-700 font-medium" placeholder="votre@email.com">
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="space-y-2">
                        <label class="text-[10px] font-black text-gray-500 uppercase tracking-widest ml-1">Mot de passe</label>
                        <input type="password" name="password" required class="w-full px-4 py-4 bg-black/20 border border-white/5 rounded-2xl text-white focus:outline-none transition-all placeholder:text-gray-600 font-medium text-sm" placeholder="8+ car.">
                    </div>
                    <div class="space-y-2">
                        <label class="text-[10px] font-black text-gray-500 uppercase tracking-widest ml-1">Confirmation</label>
                        <input type="password" name="confirmPassword" required class="w-full px-4 py-4 bg-black/20 border border-white/5 rounded-2xl text-white focus:outline-none transition-all placeholder:text-gray-600 font-medium text-sm" placeholder="Répéter">
                    </div>
                </div>

                <button type="submit" class="w-full bg-gold text-dark font-black py-5 rounded-2xl hover:scale-[1.02] active:scale-95 transition-all shadow-xl shadow-gold/20 uppercase text-xs tracking-widest border border-gold-light/20">
                    S'inscrire maintenant
                </button>
            </form>

            <div class="text-center pt-4">
                <p class="text-gray-500 text-xs font-semibold">Déjà membre ? <a href="/login" class="text-gold font-bold hover:underline">Accéder au terminal</a></p>
            </div>
        </div>
    </div>
</div>
