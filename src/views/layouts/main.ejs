<!DOCTYPE html>
<html lang="fr" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? `${title} | KuronaBot` : 'KuronaBot Builder - Excellence & Technologie' %></title>
    
    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                    },
                    colors: {
                        gold: {
                            DEFAULT: '#d4a373',
                            light: '#e5c07b',
                            dark: '#c18a56',
                            glow: 'rgba(212, 163, 115, 0.4)'
                        },
                        dark: {
                            DEFAULT: '#0B0E14',
                            card: '#121417',
                            sidebar: '#1A1E26'
                        }
                    },
                    animation: {
                        'pulse-slow': 'pulse 3s cubic-bezier(0.4, 0, 0.6, 1) infinite',
                    }
                }
            }
        }
    </script>
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/custom.css">
    
    <!-- Alpine.js -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    
    <style>
        [x-cloak] { display: none !important; }
        
        /* Animation Elastique Dropdown */
        .dropdown-elastic-enter {
            transform: translateY(-20px) scale(0.9);
            opacity: 0;
        }
        .dropdown-elastic-enter-active {
            transition: all 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
        }
        .dropdown-elastic-enter-to {
            transform: translateY(0) scale(1);
            opacity: 1;
        }

        /* Sidebar Curved Indicator - L'effet "Vague" */
        .sidebar-indicator {
            position: absolute;
            left: 0;
            width: 100%;
            height: 48px;
            background-color: #0B0E14; /* Couleur du fond pour masquer la sidebar */
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.1);
            pointer-events: none;
            z-index: 10;
        }
        .sidebar-indicator::before,
        .sidebar-indicator::after {
            content: '';
            position: absolute;
            right: 0;
            width: 24px;
            height: 24px;
            background-color: transparent;
            z-index: 11;
        }
        .sidebar-indicator::before {
            top: -24px;
            border-bottom-right-radius: 20px;
            box-shadow: 8px 8px 0 8px #0B0E14;
        }
        .sidebar-indicator::after {
            bottom: -24px;
            border-top-right-radius: 20px;
            box-shadow: 8px -8px 0 8px #0B0E14;
        }

        body {
            background-color: #0B0E14;
            color: #F8F9FA;
            font-feature-settings: "cv02", "cv03", "cv04", "cv11";
        }

        .gold-gradient-text {
            background: linear-gradient(135deg, #d4a373 0%, #f5b041 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
    </style>
</head>
<body class="flex min-h-screen overflow-x-hidden selection:bg-gold/30 selection:text-gold" x-data="{ mobileMenu: false }">
    
    <% if (typeof user !== 'undefined' && user) { %>
        <!-- Sidebar Hamburger / Navigation -->
        <aside 
            x-data="{ expanded: false, activeIndex: <%= typeof activeMenu !== 'undefined' ? (['dashboard', 'bots', 'marketplace', 'forum', 'subscription', 'admin', 'profile', 'notifications'].indexOf(activeMenu) + 1) : 1 %> }" 
            @mouseenter="expanded = true" 
            @mouseleave="expanded = false"
            :class="expanded ? 'w-64 shadow-[20px_0_50px_rgba(0,0,0,0.5)]' : 'w-20'"
            class="hidden md:flex flex-col bg-dark-sidebar border-r border-white/5 transition-all duration-500 ease-[cubic-bezier(0.2,0,0,1)] fixed h-full z-50 group"
        >
            <!-- Logo Section -->
            <div class="p-5 flex items-center justify-center h-24 border-b border-white/5">
                <div class="w-12 h-12 relative group-hover:scale-110 transition-transform duration-500">
                    <img src="https://i.pinimg.com/736x/84/01/2f/84012f2c86e00e844a49c903901f4640.jpg" alt="Kurona Logo" class="w-full h-full rounded-2xl object-cover shadow-[0_0_15px_rgba(212,163,115,0.4)] border border-gold/30">
                </div>
                <span x-show="expanded" x-transition:enter="delay-150 transition-opacity duration-300" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100" class="ml-4 font-bold text-xl tracking-tight gold-gradient-text whitespace-nowrap">KuronaBot</span>
            </div>

            <!-- Navigation Links -->
            <nav class="flex-1 mt-8 relative">
                <!-- Curved "Wave" Indicator -->
                <div 
                    x-show="activeIndex > 0"
                    class="sidebar-indicator" 
                    :style="`top: ${(activeIndex - 1) * 64 + 32}px`"
                ></div>

                <div class="space-y-4 px-4 relative z-20">
                    <a href="/dashboard" @mouseenter="activeIndex = 1" class="flex items-center h-12 rounded-2xl transition-all duration-300 relative group/item" :class="activeIndex === 1 ? 'text-gold' : 'text-gray-500 hover:text-white'">
                        <div class="w-12 flex items-center justify-center shrink-0">
                            <i data-lucide="layout-dashboard" class="w-5 h-5"></i>
                        </div>
                        <span x-show="expanded" class="ml-2 font-semibold text-sm">Tableau de bord</span>
                    </a>

                    <a href="/bots/new" @mouseenter="activeIndex = 2" class="flex items-center h-12 rounded-2xl transition-all duration-300 relative group/item" :class="activeIndex === 2 ? 'text-gold' : 'text-gray-500 hover:text-white'">
                        <div class="w-12 flex items-center justify-center shrink-0">
                            <i data-lucide="zap" class="w-5 h-5"></i>
                        </div>
                        <span x-show="expanded" class="ml-2 font-semibold text-sm">Architecture Bot</span>
                    </a>

                    <a href="/marketplace" @mouseenter="activeIndex = 3" class="flex items-center h-12 rounded-2xl transition-all duration-300 relative group/item" :class="activeIndex === 3 ? 'text-gold' : 'text-gray-500 hover:text-white'">
                        <div class="w-12 flex items-center justify-center shrink-0">
                            <i data-lucide="shopping-bag" class="w-5 h-5"></i>
                        </div>
                        <span x-show="expanded" class="ml-2 font-semibold text-sm">Marketplace</span>
                    </a>

                    <a href="/forum" @mouseenter="activeIndex = 4" class="flex items-center h-12 rounded-2xl transition-all duration-300 relative group/item" :class="activeIndex === 4 ? 'text-gold' : 'text-gray-500 hover:text-white'">
                        <div class="w-12 flex items-center justify-center shrink-0">
                            <i data-lucide="message-square" class="w-5 h-5"></i>
                        </div>
                        <span x-show="expanded" class="ml-2 font-semibold text-sm">Le Hangar</span>
                    </a>

                    <a href="/payment/plans" @mouseenter="activeIndex = 5" class="flex items-center h-12 rounded-2xl transition-all duration-300 relative group/item" :class="activeIndex === 5 ? 'text-gold' : 'text-gray-500 hover:text-white'">
                        <div class="w-12 flex items-center justify-center shrink-0">
                            <i data-lucide="crown" class="w-5 h-5"></i>
                        </div>
                        <span x-show="expanded" class="ml-2 font-semibold text-sm">Abonnement</span>
                    </a>

                    <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
                    <a href="/admin" @mouseenter="activeIndex = 6" class="flex items-center h-12 rounded-2xl transition-all duration-300 relative group/item" :class="activeIndex === 6 ? 'text-gold' : 'text-gray-500 hover:text-white'">
                        <div class="w-12 flex items-center justify-center shrink-0">
                            <i data-lucide="shield-check" class="w-5 h-5"></i>
                        </div>
                        <span x-show="expanded" class="ml-2 font-semibold text-sm">Contrôle Admin</span>
                    </a>
                    <% } %>

                    <a href="/profile" @mouseenter="activeIndex = 7" class="flex items-center h-12 rounded-2xl transition-all duration-300 relative group/item" :class="activeIndex === 7 ? 'text-gold' : 'text-gray-500 hover:text-white'">
                        <div class="w-12 flex items-center justify-center shrink-0">
                            <i data-lucide="settings" class="w-5 h-5"></i>
                        </div>
                        <span x-show="expanded" class="ml-2 font-semibold text-sm">Profil</span>
                    </a>

                    <a href="/notifications" @mouseenter="activeIndex = 8" class="flex items-center h-12 rounded-2xl transition-all duration-300 relative group/item" :class="activeIndex === 8 ? 'text-gold' : 'text-gray-500 hover:text-white'">
                        <div class="w-12 flex items-center justify-center shrink-0">
                            <i data-lucide="bell" class="w-5 h-5"></i>
                        </div>
                        <span x-show="expanded" class="ml-2 font-semibold text-sm">Alertes</span>
                    </a>
                </div>
            </nav>

            <!-- Bottom Section -->
            <div class="p-4 border-t border-white/5 space-y-2">
                <a href="/logout" class="flex items-center h-12 rounded-2xl text-red-400 hover:bg-red-400/5 transition-all duration-300 px-4 group/logout">
                    <div class="w-12 flex items-center justify-center shrink-0">
                        <i data-lucide="power" class="w-5 h-5 group-hover/logout:scale-110 transition-transform"></i>
                    </div>
                    <span x-show="expanded" class="ml-2 font-bold text-xs uppercase tracking-widest">Déconnexion</span>
                </a>
            </div>
        </aside>
    <% } %>

    <div class="flex-1 flex flex-col <%= (typeof user !== 'undefined' && user) ? 'md:ml-20' : '' %> min-w-0">
        <!-- Modern Header -->
        <header class="h-24 bg-dark/60 backdrop-blur-2xl border-b border-white/5 sticky top-0 z-40 px-8 flex items-center justify-between">
            <div class="flex items-center">
                <button @click="mobileMenu = true" class="md:hidden mr-4 p-2 text-gray-400 hover:text-white bg-white/5 rounded-xl border border-white/5">
                    <i data-lucide="menu" class="w-6 h-6"></i>
                </button>
                <div class="flex flex-col">
                    <span class="text-[10px] font-black text-gold/60 uppercase tracking-[0.3em] mb-0.5">SYSTÈME OPÉRATIONNEL</span>
                    <h1 class="text-xl font-bold text-white tracking-tight"><%= typeof title !== 'undefined' ? title : 'Dashboard' %></h1>
                </div>
            </div>

            <div class="flex items-center space-x-6">
                <% if (typeof user !== 'undefined' && user) { %>
                    <!-- Stats Quick View (Desktop Only) -->
                    <div class="hidden lg:flex items-center space-x-8 px-6 py-2 bg-white/5 border border-white/5 rounded-2xl mr-4">
                        <div class="flex flex-col">
                            <span class="text-[9px] text-gray-500 font-bold uppercase tracking-widest">Temps d'activité</span>
                            <span class="text-xs font-mono text-gold">99.9%</span>
                        </div>
                        <div class="w-px h-6 bg-white/10"></div>
                        <div class="flex flex-col">
                            <span class="text-[9px] text-gray-500 font-bold uppercase tracking-widest">Bots Actifs</span>
                            <span class="text-xs font-mono text-gold">--</span>
                        </div>
                    </div>

                    <!-- Profile Dropdown -->
                    <div x-data="{ open: false }" class="relative">
                        <button 
                            @click="open = !open" 
                            class="flex items-center space-x-4 p-1.5 pl-4 pr-3 bg-white/5 hover:bg-white/10 rounded-2xl border border-white/10 transition-all duration-500 hover:border-gold/30 group"
                        >
                            <span class="text-sm font-bold text-white/90 group-hover:text-white transition-colors"><%= user.username %></span>
                            <div class="w-9 h-9 rounded-xl bg-gold/20 flex items-center justify-center text-gold border border-gold/20 shadow-inner group-hover:shadow-gold/20 group-hover:scale-105 transition-all">
                                <i data-lucide="user" class="w-5 h-5"></i>
                            </div>
                            <i data-lucide="chevron-down" class="w-4 h-4 text-gray-500 transition-transform duration-500" :class="open ? 'rotate-180 text-gold' : ''"></i>
                        </button>

                        <div 
                            x-show="open" 
                            x-cloak
                            @click.away="open = false"
                            class="absolute right-0 mt-4 w-64 bg-dark-card border border-white/10 rounded-3xl shadow-[0_10px_40px_rgba(0,0,0,0.6)] p-3 z-50 origin-top-right overflow-hidden"
                            x-transition:enter="dropdown-elastic-enter-active"
                            x-transition:enter-start="dropdown-elastic-enter"
                            x-transition:enter-end="dropdown-elastic-enter-to"
                            x-transition:leave="transition ease-in duration-200"
                            x-transition:leave-start="opacity-100 scale-100"
                            x-transition:leave-end="opacity-0 scale-95"
                        >
                            <!-- Decor -->
                            <div class="absolute -top-10 -right-10 w-24 h-24 bg-gold/5 rounded-full blur-2xl"></div>

                            <a href="/profile" class="flex items-center space-x-3 px-4 py-3.5 rounded-2xl text-gray-400 hover:text-gold hover:bg-white/5 hover:translate-x-1 transition-all duration-300 relative group/link">
                                <i data-lucide="user-cog" class="w-4 h-4"></i>
                                <span class="text-sm font-semibold">Mon Profil</span>
                                <i data-lucide="arrow-right" class="w-3 h-3 ml-auto opacity-0 group-hover/link:opacity-100 transition-all"></i>
                            </a>
                            <a href="/notifications" class="flex items-center space-x-3 px-4 py-3.5 rounded-2xl text-gray-400 hover:text-gold hover:bg-white/5 hover:translate-x-1 transition-all duration-300 relative group/link">
                                <i data-lucide="bell-ring" class="w-4 h-4"></i>
                                <span class="text-sm font-semibold">Notifications</span>
                            </a>
                            <div class="h-px bg-white/5 my-2"></div>
                            <a href="/logout" class="flex items-center space-x-3 px-4 py-3.5 rounded-2xl text-red-500/80 hover:text-red-500 hover:bg-red-500/5 transition-all duration-300">
                                <i data-lucide="log-out" class="w-4 h-4"></i>
                                <span class="text-sm font-bold uppercase tracking-widest text-[10px]">Déconnexion</span>
                            </a>
                        </div>
                    </div>
                <% } else { %>
                    <div class="flex items-center space-x-6">
                        <a href="/login" class="text-sm font-bold text-gray-400 hover:text-white transition-colors uppercase tracking-widest">Connexion</a>
                        <a href="/register" class="bg-gold text-dark font-black px-8 py-3.5 rounded-2xl hover:scale-105 active:scale-95 transition-all shadow-xl shadow-gold/20 text-xs uppercase tracking-widest border border-gold-light/20">S'inscrire</a>
                    </div>
                <% } %>
            </div>
        </header>

        <!-- Main Content with Fade Effect -->
        <main class="flex-1 p-8 md:p-12 max-w-[1600px] mx-auto w-full" x-data="{ loaded: false }" x-init="setTimeout(() => loaded = true, 50)" :class="loaded ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-4'" class="transition-all duration-700 ease-out">
            <%- body %>
        </main>

        <!-- Sophisticated Footer -->
        <footer class="py-12 px-10 border-t border-white/5 bg-white/[0.01]">
            <div class="max-w-[1600px] mx-auto flex flex-col md:flex-row items-center justify-between">
                <div class="flex flex-col items-center md:items-start space-y-2">
                    <div class="flex items-center space-x-2">
                        <div class="w-6 h-6 bg-gold rounded-lg flex items-center justify-center">
                            <span class="text-dark font-black text-[10px]">K</span>
                        </div>
                        <span class="text-sm font-bold text-white tracking-widest">KURONABOT <span class="text-gold">BUILDER</span></span>
                    </div>
                    <p class="text-gray-600 text-xs font-medium">L'Excellence de l'Automatisation WhatsApp.</p>
                </div>
                
                <div class="flex items-center space-x-12 mt-8 md:mt-0">
                    <div class="flex flex-col space-y-2">
                        <span class="text-[9px] font-black text-gray-500 uppercase tracking-[0.2em] mb-1">Navigation</span>
                        <a href="/dashboard" class="text-xs text-gray-400 hover:text-gold transition-colors">Accueil</a>
                        <a href="/bots/new" class="text-xs text-gray-400 hover:text-gold transition-colors">Architecture</a>
                    </div>
                    <div class="flex flex-col space-y-2">
                        <span class="text-[9px] font-black text-gray-500 uppercase tracking-[0.2em] mb-1">Légal</span>
                        <a href="#" class="text-xs text-gray-400 hover:text-gold transition-colors">Terms of Service</a>
                        <a href="#" class="text-xs text-gray-400 hover:text-gold transition-colors">Privacy Policy</a>
                    </div>
                </div>
            </div>
            <div class="max-w-[1600px] mx-auto mt-12 pt-8 border-t border-white/[0.03] flex justify-center lg:justify-between items-center text-[10px] text-gray-700 font-bold uppercase tracking-widest">
                <p>&copy; 2026 KURONABOT CORP. ALL RIGHTS RESERVED - PLATINUM EDITION</p>
                <div class="hidden lg:flex items-center space-x-4">
                    <i data-lucide="shield-check" class="w-4 h-4 opacity-30"></i>
                    <span>SSL ENCRYPTED SECURE INFRASTRUCTURE</span>
                </div>
            </div>
        </footer>
    </div>

    <!-- Mobile Overlay Menu -->
    <div x-show="mobileMenu" 
         x-cloak
         x-transition:enter="transition ease-out duration-300"
         x-transition:enter-start="opacity-0"
         x-transition:enter-end="opacity-100"
         x-transition:leave="transition ease-in duration-200"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0"
         class="fixed inset-0 bg-dark/95 backdrop-blur-xl z-[100] flex flex-col p-8 md:hidden"
    >
        <div class="flex justify-between items-center mb-12">
            <div class="flex items-center space-x-3">
                <div class="w-10 h-10 bg-gold rounded-xl flex items-center justify-center">
                    <span class="text-dark font-black">K</span>
                </div>
                <span class="font-bold text-xl tracking-tight text-white">KuronaBot</span>
            </div>
            <button @click="mobileMenu = false" class="p-2 bg-white/5 border border-white/10 rounded-xl text-gray-400 hover:text-white">
                <i data-lucide="x" class="w-6 h-6"></i>
            </button>
        </div>

        <nav class="flex-1 flex flex-col space-y-6">
            <a href="/dashboard" class="text-3xl font-bold flex items-center group">
                <i data-lucide="layout-dashboard" class="w-8 h-8 mr-4 group-hover:text-gold transition-colors"></i>
                Tableau de bord
            </a>
            <a href="/bots/new" class="text-3xl font-bold flex items-center group">
                <i data-lucide="zap" class="w-8 h-8 mr-4 group-hover:text-gold transition-colors"></i>
                Nouveau Bot
            </a>
            <a href="/profile" class="text-3xl font-bold flex items-center group">
                <i data-lucide="user" class="w-8 h-8 mr-4 group-hover:text-gold transition-colors"></i>
                Profil
            </a>
        </nav>

        <div class="pt-8 border-t border-white/5 flex flex-col space-y-4">
            <% if (typeof user !== 'undefined' && user) { %>
                <a href="/logout" class="text-red-500 font-bold flex items-center">
                    <i data-lucide="log-out" class="w-6 h-6 mr-3"></i>
                    Déconnexion
                </a>
            <% } else { %>
                <a href="/login" class="text-white font-bold">Connexion</a>
                <a href="/register" class="text-gold font-bold">S'inscrire</a>
            <% } %>
        </div>
    </div>

    <script>
        lucide.createIcons();
    </script>
</body>
</html>
