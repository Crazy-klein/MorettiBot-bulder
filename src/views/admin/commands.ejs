<div class="space-y-10" x-data="{
    freeLimit: '<%= freeLimit %>',
    async updateLimit() {
        const res = await fetch('/api/admin/settings/free_limit', {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ limit: this.freeLimit })
        });
        if(res.ok) alert('Limite mise à jour');
    },
    async toggleCommand(id, field, value) {
        await fetch(`/api/admin/commands/${id}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ [field]: value })
        });
    }
}">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 px-2">
        <div>
            <div class="flex items-center space-x-3 mb-3">
                <div class="w-10 h-10 glass rounded-xl flex items-center justify-center text-gold">
                    <i data-lucide="terminal" class="w-5 h-5"></i>
                </div>
                <span class="text-[10px] font-black text-gray-500 uppercase tracking-[0.3em]">Module de Contrôle</span>
            </div>
            <h2 class="text-4xl font-black text-white tracking-tight">Gestion des <span class="gold-gradient-text italic">Commandes</span></h2>
            <p class="text-gray-500 font-medium mt-1">Configurez la disponibilité et la monétisation des algorithmes.</p>
        </div>
        
        <div class="glass p-6 rounded-[2rem] border border-white/5 flex items-center space-x-6">
            <div>
                <p class="text-[9px] font-black text-gray-500 uppercase tracking-widest mb-1">Limite Offre Gratuite</p>
                <input type="number" x-model="freeLimit" @change="updateLimit" class="bg-black/40 border border-white/5 rounded-xl px-4 py-2 text-white font-black w-24 focus:outline-none focus:border-gold transition-all">
            </div>
            <div class="w-px h-10 bg-white/5"></div>
            <div class="text-right">
                <p class="text-[9px] font-black text-gray-500 uppercase tracking-widest mb-1">Total Commandes</p>
                <p class="text-xl font-black text-gold"><%= commands.length %></p>
            </div>
        </div>
    </div>

    <!-- Interface Table -->
    <div class="glass rounded-[3.5rem] border border-white/5 overflow-hidden shadow-2xl">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="text-[9px] text-gray-500 uppercase tracking-[0.3em] font-black border-b border-white/[0.03] bg-white/[0.01]">
                        <th class="px-10 py-6">Commande / Clé</th>
                        <th class="px-10 py-6">Catégorie</th>
                        <th class="px-10 py-6">Description</th>
                        <th class="px-10 py-6 text-center">Monétisation</th>
                        <th class="px-10 py-6 text-center">Statut Système</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-white/[0.02]">
                    <% commands.forEach(cmd => { %>
                    <tr class="hover:bg-white/[0.01] transition-all group" x-data="{ isFree: <%= cmd.isFree === 1 %>, isActive: <%= cmd.isActive === 1 %> }">
                        <td class="px-10 py-6">
                            <span class="text-white font-black uppercase tracking-tight block"><%= cmd.name %></span>
                            <code class="text-[9px] font-mono text-gold/40 mt-1 block tracking-wider"><%= cmd.key %></code>
                        </td>
                        <td class="px-10 py-6">
                            <span class="px-3 py-1 glass rounded-lg text-[9px] font-black uppercase tracking-widest text-gray-500 border border-white/5 group-hover:border-gold/20 group-hover:text-gold/60 transition-all"><%= cmd.category %></span>
                        </td>
                        <td class="px-10 py-6">
                            <p class="text-[10px] text-gray-600 font-medium italic truncate max-w-xs"><%= cmd.description || 'Aucune description' %></p>
                        </td>
                        <td class="px-10 py-6 text-center">
                            <button @click="isFree = !isFree; toggleCommand(<%= cmd.id %>, 'isFree', isFree)" 
                                    class="w-20 py-2 rounded-full text-[9px] font-black uppercase tracking-widest transition-all border outline-none"
                                    :class="isFree ? 'bg-green-500/10 text-green-500 border-green-500/20' : 'bg-gold/10 text-gold border-gold/20 shadow-[0_0_15px_rgba(212,163,115,0.15)]'">
                                <span x-text="isFree ? 'Gratuit' : 'Payant'"></span>
                            </button>
                        </td>
                        <td class="px-10 py-6 text-center">
                            <button @click="isActive = !isActive; toggleCommand(<%= cmd.id %>, 'isActive', isActive)" 
                                    class="w-20 py-2 rounded-full text-[9px] font-black uppercase tracking-widest transition-all border outline-none"
                                    :class="isActive ? 'bg-white/5 text-white/50 border-white/10' : 'bg-red-500/10 text-red-500 border-red-500/20'">
                                <span x-text="isActive ? 'En Ligne' : 'Hors Ligne'"></span>
                            </button>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>
