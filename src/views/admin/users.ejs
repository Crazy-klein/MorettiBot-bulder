<div class="space-y-10">
    <div class="flex items-center justify-between">
        <div>
            <h2 class="text-3xl font-bold text-white mb-2">Gestion des Utilisateurs</h2>
            <p class="text-gray-500">Liste exhaustive des membres inscrits sur la plateforme.</p>
        </div>
        <a href="/admin" class="text-gray-500 hover:text-white flex items-center text-sm font-medium transition-colors">
            <i data-lucide="arrow-left" class="w-4 h-4 mr-2"></i>
            Retour Stats
        </a>
    </div>

    <div class="bg-dark-card border border-white/5 rounded-[2.5rem] overflow-hidden shadow-2xl">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="text-[10px] text-gray-500 uppercase tracking-widest font-bold border-b border-white/5 bg-white/[0.02]">
                        <th class="px-8 py-4">Utilisateur</th>
                        <th class="px-8 py-4">Email</th>
                        <th class="px-8 py-4">Rôle Actuel</th>
                        <th class="px-8 py-4">Date d'inscription</th>
                        <th class="px-8 py-4 text-center">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-white/[0.05]">
                    <% users.forEach(u => { %>
                    <tr class="hover:bg-white/[0.01] transition-colors group">
                        <td class="px-8 py-5">
                            <div class="flex items-center space-x-3">
                                <div class="w-10 h-10 rounded-xl bg-gold/10 flex items-center justify-center text-gold font-bold">
                                    <%= u.username.substring(0, 1).toUpperCase() %>
                                </div>
                                <span class="text-white font-semibold"><%= u.username %></span>
                            </div>
                        </td>
                        <td class="px-8 py-5 text-sm text-gray-400">
                            <%= u.email %>
                        </td>
                        <td class="px-8 py-5">
                            <span class="px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest border <%= u.role === 'admin' ? 'bg-gold/10 text-gold border-gold/20' : 'bg-white/5 text-gray-500 border-white/10' %>">
                                <%= u.role %>
                            </span>
                        </td>
                        <td class="px-8 py-5 text-xs text-gray-500">
                            <%= new Date(u.createdAt).toLocaleDateString('fr-FR') %>
                        </td>
                        <td class="px-8 py-5">
                            <form action="/admin/users/<%= u.id %>/role" method="POST" class="flex items-center justify-center">
                                <select name="role" onchange="this.form.submit()" class="bg-white/5 border border-white/10 rounded-xl text-xs text-gray-300 px-3 py-2 outline-none focus:border-gold transition-all">
                                    <option value="user" <%= u.role === 'user' ? 'selected' : '' %>>Utilisateur</option>
                                    <option value="admin" <%= u.role === 'admin' ? 'selected' : '' %>>Administrateur</option>
                                </select>
                            </form>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>
