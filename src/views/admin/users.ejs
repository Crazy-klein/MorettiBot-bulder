<div class="space-y-12">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 px-2">
        <div>
            <div class="flex items-center space-x-3 mb-3">
                <div class="w-10 h-10 glass rounded-xl flex items-center justify-center text-gold">
                    <i data-lucide="users" class="w-5 h-5"></i>
                </div>
                <span class="text-[10px] font-black text-gray-500 uppercase tracking-[0.3em]">Protocole de hiérarchie</span>
            </div>
            <h2 class="text-4xl font-black text-white tracking-tight">Registre des <span class="gold-gradient-text italic">Architectes</span></h2>
            <p class="text-gray-500 font-medium mt-1">Base de données exhaustive des identités numériques actives sur le réseau.</p>
        </div>
        <a href="/admin" class="glass px-6 py-3 rounded-xl text-gray-400 hover:text-white flex items-center text-[10px] font-black uppercase tracking-widest transition-all hover:border-white/20">
            <i data-lucide="arrow-left" class="w-3.5 h-3.5 mr-2"></i>
            Console Admin
        </a>
    </div>

    <!-- Users Advanced Table -->
    <div class="glass rounded-[4rem] border border-white/5 overflow-hidden shadow-[0_40px_120px_rgba(0,0,0,0.6)]">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="text-[9px] text-gray-500 uppercase tracking-[0.3em] font-black border-b border-white/[0.03] bg-white/[0.01]">
                        <th class="px-12 py-8">Identité / Avatar</th>
                        <th class="px-12 py-8">Point d'Accès (Email)</th>
                        <th class="px-12 py-8">Niveau de Privilège</th>
                        <th class="px-12 py-8">Enregistrement au Registre</th>
                        <th class="px-12 py-8 text-center">Élévation de Rôle</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-white/[0.02]">
                    <% users.forEach(u => { %>
                    <tr class="hover:bg-white/[0.01] transition-all duration-300 group">
                        <td class="px-12 py-8">
                            <div class="flex items-center space-x-5">
                                <div class="w-12 h-12 rounded-2xl bg-gold/10 border border-gold/20 flex items-center justify-center text-gold font-black text-lg group-hover:scale-110 transition-transform shadow-[0_0_20px_rgba(212,163,115,0.1)]">
                                    <%= u.username.substring(0, 1).toUpperCase() %>
                                </div>
                                <div>
                                    <span class="text-sm text-white font-black uppercase tracking-tight group-hover:text-gold transition-colors"><%= u.username %></span>
                                    <div class="flex items-center mt-1">
                                        <span class="w-1.5 h-1.5 bg-green-500 rounded-full mr-2 opacity-50"></span>
                                        <span class="text-[8px] font-black text-gray-700 uppercase tracking-widest">Actif</span>
                                    </div>
                                </div>
                            </div>
                        </td>
                        <td class="px-12 py-8 text-xs font-medium text-gray-400 group-hover:text-gray-300 transition-colors">
                            <%= u.email %>
                        </td>
                        <td class="px-12 py-8">
                            <span class="px-5 py-1.5 rounded-full text-[9px] font-black uppercase tracking-widest border transition-all <%= u.role === 'admin' ? 'bg-gold/10 text-gold border-gold/20 shadow-[0_0_15px_rgba(212,163,115,0.1)]' : 'bg-white/5 text-gray-600 border-white/10' %>">
                                <%= u.role %>
                            </span>
                        </td>
                        <td class="px-12 py-8 text-[11px] font-bold text-gray-500 uppercase tracking-widest">
                            <%= new Date(u.createdAt).toLocaleDateString('fr-FR', {day: '2-digit', month: 'short', year: 'numeric'}) %>
                        </td>
                        <td class="px-12 py-8">
                            <form action="/admin/users/<%= u.id %>/role" method="POST" class="flex items-center justify-center">
                                <div class="relative group/select">
                                    <select name="role" onchange="this.form.submit()" class="bg-black/40 border border-white/5 rounded-xl text-[10px] font-black uppercase tracking-widest text-gold px-6 py-3 outline-none focus:border-gold/50 transition-all hover:bg-gold hover:text-dark cursor-pointer appearance-none">
                                        <option value="user" <%= u.role === 'user' ? 'selected' : '' %>>User Standard</option>
                                        <option value="admin" <%= u.role === 'admin' ? 'selected' : '' %>>Elite Admin</option>
                                    </select>
                                    <i data-lucide="chevron-down" class="absolute right-2 top-1/2 -translate-y-1/2 w-3 h-3 pointer-events-none opacity-50 group-hover/select:opacity-100 group-hover/select:text-dark"></i>
                                </div>
                            </form>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>
