<div class="space-y-10">
    <div class="flex items-center justify-between">
        <div>
            <h2 class="text-3xl font-bold text-white mb-2">Administration</h2>
            <p class="text-gray-500">Vue d'ensemble de la plateforme KuronaBot Builder.</p>
        </div>
        <div class="flex space-x-3">
            <a href="/admin/users" class="bg-white/5 text-white hover:bg-white/10 px-6 py-3 rounded-2xl border border-white/10 transition-all font-medium flex items-center">
                <i data-lucide="users" class="w-4 h-4 mr-2"></i>
                Utilisateurs
            </a>
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-dark-card border border-white/5 p-8 rounded-[2.5rem] relative overflow-hidden group">
            <div class="absolute -right-6 -bottom-6 w-32 h-32 bg-blue-500/5 rounded-full group-hover:scale-110 transition-transform"></div>
            <div class="flex items-center space-x-4 mb-6">
                <div class="w-12 h-12 bg-blue-500/10 rounded-xl flex items-center justify-center text-blue-400">
                    <i data-lucide="users"></i>
                </div>
                <h4 class="text-gray-400 font-bold text-sm uppercase tracking-widest">Utilisateurs</h4>
            </div>
            <p class="text-4xl font-bold text-white"><%= stats.userCount %></p>
            <p class="text-xs text-gray-500 mt-2 font-medium">+15% ce mois-ci</p>
        </div>

        <div class="bg-dark-card border border-white/5 p-8 rounded-[2.5rem] relative overflow-hidden group">
            <div class="absolute -right-6 -bottom-6 w-32 h-32 bg-gold/5 rounded-full group-hover:scale-110 transition-transform"></div>
            <div class="flex items-center space-x-4 mb-6">
                <div class="w-12 h-12 bg-gold/10 rounded-xl flex items-center justify-center text-gold">
                    <i data-lucide="bot"></i>
                </div>
                <h4 class="text-gray-400 font-bold text-sm uppercase tracking-widest">Bots Créés</h4>
            </div>
            <p class="text-4xl font-bold text-white"><%= stats.botCount %></p>
            <p class="text-xs text-gray-500 mt-2 font-medium">Répartis sur 3 types</p>
        </div>

        <div class="bg-dark-card border border-white/5 p-8 rounded-[2.5rem] relative overflow-hidden group">
            <div class="absolute -right-6 -bottom-6 w-32 h-32 bg-green-500/5 rounded-full group-hover:scale-110 transition-transform"></div>
            <div class="flex items-center space-x-4 mb-6">
                <div class="w-12 h-12 bg-green-500/10 rounded-xl flex items-center justify-center text-green-400">
                    <i data-lucide="zap"></i>
                </div>
                <h4 class="text-gray-400 font-bold text-sm uppercase tracking-widest">Sessions Actives</h4>
            </div>
            <p class="text-4xl font-bold text-white"><%= stats.activeSessions %></p>
            <p class="text-xs text-gray-400 mt-2 font-medium flex items-center">
                <span class="w-2 h-2 bg-green-500 rounded-full mr-2 animate-pulse"></span>
                Temps réel
            </p>
        </div>
    </div>

    <!-- Logs Table -->
    <div class="bg-dark-card border border-white/5 rounded-[2.5rem] overflow-hidden">
        <div class="px-8 py-6 border-b border-white/5 flex items-center justify-between bg-white/[0.02]">
            <h3 class="text-lg font-bold text-white">Journal d'Audit Global</h3>
            <span class="text-[10px] font-bold text-gold uppercase tracking-widest bg-gold/10 px-3 py-1 rounded-full">Dernières 20 actions</span>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="text-[10px] text-gray-500 uppercase tracking-widest font-bold border-b border-white/5">
                        <th class="px-8 py-4">Utilisateur</th>
                        <th class="px-8 py-4">Action</th>
                        <th class="px-8 py-4">Détails</th>
                        <th class="px-8 py-4">Date</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-white/[0.05]">
                    <% recentLogs.forEach(log => { %>
                    <tr class="hover:bg-white/[0.01] transition-colors group">
                        <td class="px-8 py-5">
                            <div class="flex items-center space-x-3">
                                <div class="w-8 h-8 rounded-full bg-white/5 flex items-center justify-center text-gray-500 font-bold text-xs uppercase group-hover:bg-gold/10 group-hover:text-gold transition-colors">
                                    <%= log.username.substring(0, 1) %>
                                </div>
                                <span class="text-sm text-white/80 font-medium"><%= log.username %></span>
                            </div>
                        </td>
                        <td class="px-8 py-5">
                            <span class="text-xs bg-white/5 px-3 py-1 rounded-full border border-white/10 text-gray-400"><%= log.action %></span>
                        </td>
                        <td class="px-8 py-5">
                            <p class="text-xs text-gray-500 max-w-xs truncate"><%= log.details %></p>
                        </td>
                        <td class="px-8 py-5">
                            <span class="text-[10px] font-mono text-gray-600"><%= new Date(log.createdAt).toLocaleString('fr-FR') %></span>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>
