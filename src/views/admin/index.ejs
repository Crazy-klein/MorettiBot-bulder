<div class="space-y-12">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 px-2">
        <div>
            <div class="flex items-center space-x-3 mb-3">
                <div class="w-10 h-10 glass rounded-xl flex items-center justify-center text-gold">
                    <i data-lucide="shield-check" class="w-5 h-5"></i>
                </div>
                <span class="text-[10px] font-black text-gray-500 uppercase tracking-[0.3em]">Command Center (Restreint)</span>
            </div>
            <h2 class="text-4xl font-black text-white tracking-tight">Console de <span class="gold-gradient-text italic">Haute Direction</span></h2>
            <p class="text-gray-500 font-medium mt-1">Supervision globale des structures, flux et protocoles utilisateurs.</p>
        </div>
        <div class="flex items-center space-x-4">
            <a href="/admin/commands" class="glass px-8 py-4 rounded-2xl text-[10px] font-black uppercase tracking-widest text-white hover:border-gold/20 hover:text-gold transition-all flex items-center group">
                <i data-lucide="terminal" class="w-4 h-4 mr-3 group-hover:rotate-12 transition-transform"></i>
                Commandes
            </a>
            <a href="/admin/marketplace" class="glass px-8 py-4 rounded-2xl text-[10px] font-black uppercase tracking-widest text-white hover:border-gold/20 hover:text-gold transition-all flex items-center group">
                <i data-lucide="shopping-bag" class="w-4 h-4 mr-3 group-hover:rotate-12 transition-transform"></i>
                Marketplace
            </a>
            <a href="/admin/users" class="glass px-8 py-4 rounded-2xl text-[10px] font-black uppercase tracking-widest text-white hover:border-gold/20 hover:text-gold transition-all flex items-center group">
                <i data-lucide="users" class="w-4 h-4 mr-3 group-hover:rotate-12 transition-transform"></i>
                Utilisateurs
            </a>
        </div>
    </div>

    <!-- Metrics v2 -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="glass p-10 rounded-[3rem] border border-white/5 relative overflow-hidden group">
            <div class="absolute -top-10 -right-10 w-32 h-32 bg-blue-500/5 rounded-full blur-2xl group-hover:bg-blue-500/10 transition-all duration-700"></div>
            <div class="flex items-center space-x-6 mb-10 relative z-10">
                <div class="w-14 h-14 bg-blue-500/10 rounded-2xl flex items-center justify-center text-blue-500 border border-blue-500/20 group-hover:scale-110 transition-transform shadow-[0_0_20px_rgba(59,130,246,0.1)]">
                    <i data-lucide="users-2" class="w-7 h-7"></i>
                </div>
                <span class="text-[10px] font-black text-gray-500 uppercase tracking-[0.2em] w-24">Base Utilisateurs Active</span>
            </div>
            <div class="relative z-10">
                <p class="text-5xl font-black text-white leading-none tracking-tighter"><%= stats.userCount %></p>
                <div class="flex items-center mt-4">
                    <i data-lucide="trending-up" class="w-3 h-3 text-green-500 mr-2"></i>
                    <span class="text-[9px] font-black text-green-500/80 uppercase tracking-widest">Expansion de 15%</span>
                </div>
            </div>
        </div>

        <div class="glass p-10 rounded-[3rem] border border-white/5 relative overflow-hidden group">
            <div class="absolute -top-10 -right-10 w-32 h-32 bg-gold/5 rounded-full blur-2xl group-hover:bg-gold/10 transition-all duration-700"></div>
            <div class="flex items-center space-x-6 mb-10 relative z-10">
                <div class="w-14 h-14 bg-gold/10 rounded-2xl flex items-center justify-center text-gold border border-gold/20 group-hover:scale-110 transition-transform shadow-[0_0_20px_rgba(212,163,115,0.1)]">
                    <i data-lucide="layers" class="w-7 h-7"></i>
                </div>
                <span class="text-[10px] font-black text-gray-500 uppercase tracking-[0.2em] w-24">Entités Compilées</span>
            </div>
            <div class="relative z-10">
                <p class="text-5xl font-black text-white leading-none tracking-tighter"><%= stats.botCount %></p>
                <div class="flex items-center mt-4">
                    <i data-lucide="zap" class="w-3 h-3 text-gold mr-2"></i>
                    <span class="text-[9px] font-black text-gold/80 uppercase tracking-widest">Protocoles Optimisés</span>
                </div>
            </div>
        </div>

        <div class="glass p-10 rounded-[3rem] border border-white/5 relative overflow-hidden group">
            <div class="absolute -top-10 -right-10 w-32 h-32 bg-green-500/5 rounded-full blur-2xl group-hover:bg-green-500/10 transition-all duration-700"></div>
            <div class="flex items-center space-x-6 mb-10 relative z-10">
                <div class="w-14 h-14 bg-green-500/10 rounded-2xl flex items-center justify-center text-green-500 border border-green-500/20 group-hover:scale-110 transition-transform shadow-[0_0_20px_rgba(34,197,94,0.1)]">
                    <i data-lucide="radio" class="w-7 h-7 animate-pulse"></i>
                </div>
                <span class="text-[10px] font-black text-gray-500 uppercase tracking-[0.2em] w-24">Liaisons Temps Réel</span>
            </div>
            <div class="relative z-10">
                <p class="text-5xl font-black text-white leading-none tracking-tighter"><%= stats.activeSessions %></p>
                <div class="flex items-center mt-4">
                    <span class="w-2 h-2 bg-green-500 rounded-full mr-2 shadow-[0_0_10px_rgba(34,197,94,0.6)]"></span>
                    <span class="text-[9px] font-black text-green-500/80 uppercase tracking-widest">Flux Synchronisé</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Audit Log Terminal -->
    <div class="glass rounded-[4rem] border border-white/5 overflow-hidden shadow-[0_40px_120px_rgba(0,0,0,0.6)]">
        <div class="px-12 py-10 border-b border-white/5 flex flex-col md:flex-row md:items-center justify-between bg-white/[0.01] gap-4">
            <div>
                <h3 class="text-2xl font-black text-white tracking-tighter uppercase">Registre d'Audit <span class="text-gold">Souverain</span></h3>
                <p class="text-[10px] font-bold text-gray-600 uppercase tracking-[0.2em] mt-1 italic">Interception des 20 dernières séquences d'action</p>
            </div>
            <div class="flex items-center space-x-3 glass px-5 py-2.5 rounded-2xl">
                <i data-lucide="search" class="w-3.5 h-3.5 text-gray-600"></i>
                <input type="text" placeholder="Filtrer par identité..." class="bg-transparent border-0 text-[10px] font-black uppercase tracking-widest focus:outline-none text-white placeholder:text-gray-700">
            </div>
        </div>
        
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="text-[9px] text-gray-500 uppercase tracking-[0.3em] font-black border-b border-white/[0.03]">
                        <th class="px-12 py-6">ID Architecte</th>
                        <th class="px-12 py-6">Protocole</th>
                        <th class="px-12 py-6">Données Abstraites</th>
                        <th class="px-12 py-6 text-right">Horodatage</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-white/[0.02]">
                    <% recentLogs.forEach(log => { %>
                    <tr class="hover:bg-white/[0.01] transition-all duration-300 group">
                        <td class="px-12 py-7">
                            <div class="flex items-center space-x-4">
                                <div class="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center text-gray-600 font-black text-xs uppercase group-hover:bg-gold group-hover:text-dark transition-all duration-500 shadow-inner">
                                    <%= log.username.substring(0, 1) %>
                                </div>
                                <div>
                                    <span class="text-[11px] text-white font-black uppercase tracking-widest"><%= log.username %></span>
                                    <p class="text-[9px] text-gray-700 font-bold">UID: <%= log.username.toLowerCase() %></p>
                                </div>
                            </div>
                        </td>
                        <td class="px-12 py-7">
                            <span class="text-[9px] font-black bg-gold/5 px-4 py-1.5 rounded-full border border-gold/10 text-gold uppercase tracking-widest shadow-[0_0_15px_rgba(212,163,115,0.05)]">
                                <%= log.action %>
                            </span>
                        </td>
                        <td class="px-12 py-7">
                            <p class="text-[10px] text-gray-500 font-medium italic group-hover:text-gray-400 transition-colors"><%= log.details %></p>
                        </td>
                        <td class="px-12 py-7 text-right">
                            <div class="flex flex-col items-end">
                                <span class="text-[10px] font-black text-white/50 group-hover:text-gold transition-colors"><%= new Date(log.createdAt).toLocaleDateString('fr-FR') %></span>
                                <span class="text-[9px] font-bold text-gray-700 uppercase tracking-widest mt-1"><%= new Date(log.createdAt).toLocaleTimeString('fr-FR', {hour: '2-digit', minute: '2-digit'}) %></span>
                            </div>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>
