<div class="space-y-10">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 px-2">
        <div>
            <div class="flex items-center space-x-3 mb-3">
                <div class="w-10 h-10 glass rounded-xl flex items-center justify-center text-gold">
                    <i data-lucide="shield-check" class="w-5 h-5"></i>
                </div>
                <span class="text-[10px] font-black text-gray-500 uppercase tracking-[0.3em]">Module de Modération</span>
            </div>
            <h2 class="text-4xl font-black text-white tracking-tight">Approbation <span class="gold-gradient-text italic">Marketplace</span></h2>
            <p class="text-gray-500 font-medium mt-1">Validez l'intégrité et la qualité des instances soumises par les architectes.</p>
        </div>
    </div>

    <div class="grid grid-cols-1 gap-8">
        <% if (pendingBots.length === 0) { %>
            <div class="glass p-24 rounded-[4rem] text-center border border-white/5 border-dashed">
                <div class="w-20 h-20 bg-white/5 rounded-full flex items-center justify-center mx-auto mb-6 text-gray-700">
                    <i data-lucide="check-circle" class="w-10 h-10"></i>
                </div>
                <h4 class="text-xl font-bold text-white mb-2">Protocole Stable</h4>
                <p class="text-gray-500">Aucune nouvelle soumission n'est en attente de validation.</p>
            </div>
        <% } else { %>
            <% pendingBots.forEach(bot => { %>
                <div class="glass p-10 rounded-[3.5rem] border border-white/5 flex flex-col lg:flex-row lg:items-center gap-10 relative overflow-hidden group shadow-2xl">
                    <div class="absolute inset-0 bg-gold/[0.01] group-hover:bg-gold/[0.03] transition-all duration-1000"></div>
                    
                    <div class="w-32 h-32 rounded-[2.5rem] glass p-2 border border-white/5 shrink-0 relative z-10">
                        <img src="<%= bot.logo %>" class="w-full h-full object-cover rounded-[2.2rem]">
                    </div>

                    <div class="flex-1 relative z-10">
                        <h3 class="text-2xl font-black text-white mb-2 uppercase tracking-tighter"><%= bot.name %> <span class="text-gold font-mono ml-4 text-xs font-medium">[PENDING]</span></h3>
                        <p class="text-[11px] text-gray-500 font-medium leading-relaxed mb-6 italic">"<%= bot.description %>"</p>
                        
                        <div class="flex flex-wrap items-center gap-6">
                            <div class="flex items-center space-x-2">
                                <i data-lucide="terminal" class="w-4 h-4 text-gold/60"></i>
                                <span class="text-[9px] font-black text-gray-500 uppercase tracking-widest"><%= bot.commandCount %> Commandes</span>
                            </div>
                            <div class="flex items-center space-x-2">
                                <i data-lucide="download-cloud" class="w-4 h-4 text-gold/60"></i>
                                <span class="text-[9px] font-black text-gray-400 uppercase tracking-widest"><%= bot.downloadType %></span>
                            </div>
                            <div class="flex items-center space-x-2">
                                <i data-lucide="dollar-sign" class="w-4 h-4 text-gold/60"></i>
                                <span class="text-[9px] font-black text-white uppercase tracking-widest"><%= bot.price %> FCFA</span>
                            </div>
                        </div>
                    </div>

                    <div class="flex items-center space-x-4 relative z-10 pt-6 lg:pt-0">
                        <form action="/admin/marketplace/<%= bot.id %>/approve" method="POST">
                            <button type="submit" class="bg-green-500 text-dark px-8 py-4 rounded-2xl font-black text-[9px] uppercase tracking-widest hover:scale-105 active:scale-95 transition-all shadow-lg shadow-green-500/10">Approuver</button>
                        </form>
                        <form action="/admin/marketplace/<%= bot.id %>/reject" method="POST">
                            <button type="submit" class="bg-red-500/10 text-red-500 border border-red-500/20 px-8 py-4 rounded-2xl font-black text-[9px] uppercase tracking-widest hover:bg-red-500 hover:text-white transition-all">Rejeter</button>
                        </form>
                        <a href="<%= bot.downloadUrl %>" target="_blank" class="glass px-8 py-4 rounded-2xl text-[9px] font-black uppercase tracking-widest text-gray-400 hover:text-white transition-all">Analyser Code</a>
                    </div>
                </div>
            <% }) %>
        <% } %>
    </div>
</div>
