<div class="max-w-xl mx-auto py-24 text-center">
    <div class="glass w-32 h-32 bg-red-500/5 text-red-500 rounded-[3rem] flex items-center justify-center mx-auto mb-12 border border-red-500/10 shadow-[0_20px_50px_rgba(239,68,68,0.1)] relative group">
        <i data-lucide="shield-off" class="w-16 h-16 group-hover:scale-110 transition-transform duration-500"></i>
        <div class="absolute -top-2 -right-2 w-8 h-8 glass rounded-full flex items-center justify-center border-red-500/20">
            <span class="text-[10px] font-black"><%= typeof error !== 'undefined' ? error.status : 500 %></span>
        </div>
    </div>

    <h2 class="text-4xl md:text-5xl font-black text-white tracking-tighter mb-6 uppercase">
        <%= typeof message !== 'undefined' ? message : 'Anomalie Détectée' %>
    </h2>
    
    <p class="text-gray-500 font-medium text-lg max-w-sm mx-auto mb-12">
        <%= typeof error !== 'undefined' && error.status === 404 
            ? 'Les coordonnées demandées sont introuvables dans notre base de données.' 
            : 'Un dysfonctionnement critique est survenu lors de l\'exécution du processus.' %>
    </p>
    
    <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
        <button onclick="history.back()" class="w-full sm:w-auto glass px-10 py-5 rounded-2xl text-[10px] font-black uppercase tracking-widest text-gray-400 hover:text-white hover:border-white/20 transition-all">
            Retourner au terminal
        </button>
        <a href="/" class="w-full sm:w-auto bg-gold text-dark px-10 py-5 rounded-2xl font-black text-[10px] uppercase tracking-widest hover:scale-105 active:scale-95 transition-all shadow-[0_15px_40px_rgba(212,163,115,0.3)] border border-gold-light/20">
            Navigation Racine
        </a>
    </div>

    <% if (process.env.NODE_ENV !== 'production' && typeof error !== 'undefined' && error.stack) { %>
        <div class="mt-20 glass-dark p-8 rounded-[3rem] border border-red-500/10 text-left overflow-x-auto shadow-2xl relative">
            <div class="flex items-center space-x-2 mb-6">
                <div class="w-2.5 h-2.5 rounded-full bg-red-500/40"></div>
                <span class="text-[9px] font-black text-red-500 uppercase tracking-[0.3em]">Stack Trace Détectée</span>
            </div>
            <pre class="text-red-400/70 font-mono text-[10px] leading-relaxed select-all"><%= error.stack %></pre>
        </div>
    <% } %>
</div>
