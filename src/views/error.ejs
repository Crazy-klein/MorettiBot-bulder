<div class="max-w-xl mx-auto py-20 text-center">
    <div class="w-24 h-24 bg-red-400/10 text-red-400 rounded-full flex items-center justify-center mx-auto mb-10 border-2 border-red-400/20">
        <i data-lucide="alert-triangle" class="w-12 h-12"></i>
    </div>
    <h2 class="text-4xl font-bold text-white mb-4"><%= typeof message !== 'undefined' ? message : 'Une erreur est survenue' %></h2>
    <p class="text-gray-500 mb-10 text-lg"><%= typeof error !== 'undefined' && error.status === 404 ? 'La page que vous recherchez n\'existe pas.' : 'Nous rencontrons un problème technique. Veuillez réessayer plus tard.' %></p>
    
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="javascript:history.back()" class="bg-white/5 text-white font-bold px-8 py-4 rounded-2xl hover:bg-white/10 transition-all border border-white/10 w-full sm:w-auto">
            Retour
        </a>
        <a href="/" class="bg-gold text-dark font-bold px-8 py-4 rounded-2xl hover:scale-105 transition-all shadow-xl shadow-gold/20 w-full sm:w-auto">
            Accueil
        </a>
    </div>

    <% if (process.env.NODE_ENV !== 'production' && typeof error !== 'undefined' && error.stack) { %>
        <div class="mt-20 p-6 bg-black/40 rounded-3xl border border-white/5 text-left overflow-x-auto">
            <p class="text-red-400 font-mono text-xs"><%= error.stack %></p>
        </div>
    <% } %>
</div>
