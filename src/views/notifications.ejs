<div class="max-w-5xl mx-auto py-8">
    <div class="mb-12 flex flex-col md:flex-row md:items-end justify-between gap-6 px-2">
        <div>
            <div class="flex items-center space-x-3 mb-3">
                <div class="w-10 h-10 glass rounded-xl flex items-center justify-center text-gold">
                    <i data-lucide="bell-ring" class="w-5 h-5"></i>
                </div>
                <span class="text-[10px] font-black text-gray-500 uppercase tracking-[0.3em]">Flux de Données Entrant</span>
            </div>
            <h2 class="text-4xl font-black text-white tracking-tight">Centre de <span class="gold-gradient-text italic">Communications</span></h2>
            <p class="text-gray-500 font-medium mt-1">Archives vivantes des interactions de vos instances et protocoles système.</p>
        </div>
        <form action="/api/notifications/mark-read" method="POST">
            <button type="submit" class="glass px-8 py-4 rounded-xl text-gray-400 hover:text-white flex items-center text-[10px] font-black uppercase tracking-widest transition-all hover:border-white/20 group">
                <i data-lucide="check-square" class="w-4 h-4 mr-3 text-gold/50 group-hover:text-gold transition-colors"></i>
                Marquer tout comme lu
            </button>
        </form>
    </div>

    <div class="glass rounded-[3.5rem] border border-white/5 overflow-hidden shadow-[0_30px_100px_rgba(0,0,0,0.4)]">
        <div class="divide-y divide-white/[0.03]">
            <% if (notifications.length === 0) { %>
                <div class="py-32 text-center relative overflow-hidden group">
                    <!-- Decor -->
                    <div class="absolute inset-0 bg-gold/[0.01] group-hover:bg-gold/[0.03] transition-all duration-1000"></div>
                    <div class="w-24 h-24 bg-white/5 rounded-full flex items-center justify-center mx-auto mb-8 text-gray-800 transition-transform duration-700 hover:scale-110">
                        <i data-lucide="bell" class="w-10 h-10"></i>
                    </div>
                    <h4 class="text-2xl font-black text-white mb-3">Signal Néant</h4>
                    <p class="text-gray-500 max-w-sm mx-auto font-medium leading-relaxed">Aucune transmission entrante n'a été interceptée par le centre de contrôle pour le moment.</p>
                </div>
            <% } else { %>
                <% notifications.forEach(notif => { %>
                    <div class="p-10 flex items-start space-x-8 transition-all hover:bg-white/[0.01] group relative overflow-hidden <%= notif.isRead ? 'opacity-40 grayscale-[0.5]' : '' %>">
                        <!-- Type indicator -->
                        <div class="absolute left-0 top-0 bottom-0 w-1 <%= 
                            notif.type === 'success' ? 'bg-green-500' : 
                            (notif.type === 'error' ? 'bg-red-500' : 
                            (notif.type === 'warning' ? 'bg-gold' : 'bg-blue-500')) 
                        %> opacity-30"></div>

                        <div class="w-16 h-16 rounded-[1.5rem] flex items-center justify-center shrink-0 border border-white/5 shadow-lg <%= 
                            notif.type === 'success' ? 'bg-green-500/10 text-green-500' : 
                            (notif.type === 'error' ? 'bg-red-500/10 text-red-500' : 
                            (notif.type === 'warning' ? 'bg-gold/10 text-gold' : 'bg-blue-500/10 text-blue-500')) 
                        %>">
                            <i data-lucide="<%= notif.type === 'success' ? 'check-circle' : (notif.type === 'error' ? 'alert-circle' : 'activity') %>" class="w-8 h-8"></i>
                        </div>
                        
                        <div class="flex-1 relative z-10">
                            <div class="flex items-center justify-between mb-3">
                                <h4 class="text-xl font-black text-white group-hover:text-gold transition-colors"><%= notif.title %></h4>
                                <div class="flex items-center space-x-2 bg-white/5 px-3 py-1 rounded-full border border-white/5">
                                    <i data-lucide="clock" class="w-3 h-3 text-gray-600"></i>
                                    <span class="text-[9px] text-gray-500 font-black uppercase tracking-widest leading-none"><%= new Date(notif.createdAt).toLocaleString('fr-FR', {day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit'}) %></span>
                                </div>
                            </div>
                            
                            <p class="text-gray-500 font-medium leading-relaxed mb-8 max-w-2xl"><%= notif.message %></p>
                            
                            <div class="flex items-center space-x-8">
                                <% if (!notif.isRead) { %>
                                    <form action="/api/notifications/mark-read" method="POST">
                                        <input type="hidden" name="id" value="<%= notif.id %>">
                                        <button type="submit" class="text-[9px] font-black text-gold uppercase tracking-[0.2em] hover:tracking-[0.3em] transition-all flex items-center">
                                            <i data-lucide="eye" class="w-3.5 h-3.5 mr-2"></i>
                                            Considérer comme lu
                                        </button>
                                    </form>
                                <% } %>
                                <form action="/api/notifications/delete" method="POST" onsubmit="return confirm('Purger définitivement cette transmission archive ?')">
                                    <input type="hidden" name="id" value="<%= notif.id %>">
                                    <button type="submit" class="text-[9px] font-black text-gray-700 hover:text-red-500 uppercase tracking-[0.2em] transition-all flex items-center">
                                        <i data-lucide="trash-2" class="w-3.5 h-3.5 mr-2"></i>
                                        Purger
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } %>
        </div>
    </div>
</div>
