<div class="max-w-4xl mx-auto py-8">
    <div class="mb-12 flex flex-col md:flex-row md:items-end justify-between gap-6 px-2">
        <div>
            <div class="flex items-center space-x-3 mb-3">
                <div class="w-10 h-10 glass rounded-xl flex items-center justify-center text-gold">
                    <i data-lucide="archive" class="w-5 h-5"></i>
                </div>
                <span class="text-[10px] font-black text-gray-500 uppercase tracking-[0.3em]">Héritage Système</span>
            </div>
            <h2 class="text-4xl font-black text-white tracking-tight">Archives de <span class="gold-gradient-text italic"><%= bot.name %></span></h2>
            <p class="text-gray-500 font-medium mt-1">Gérez les versions historiques et restaurez l'intégrité de votre architecture.</p>
        </div>
        <a href="/dashboard" class="glass px-6 py-3 rounded-xl text-gray-400 hover:text-white flex items-center text-[10px] font-black uppercase tracking-widest transition-all hover:border-white/20">
            <i data-lucide="arrow-left" class="w-3.5 h-3.5 mr-2"></i>
            Dashboard
        </a>
    </div>

    <div class="space-y-6">
        <% if (backups.length === 0) { %>
            <div class="glass-dark border border-white/5 border-dashed rounded-[3rem] p-24 text-center">
                <div class="w-20 h-20 bg-white/5 rounded-full flex items-center justify-center mx-auto mb-6 text-gray-700">
                    <i data-lucide="ghost" class="w-10 h-10"></i>
                </div>
                <h4 class="text-xl font-bold text-white mb-2">Aucun historique détecté</h4>
                <p class="text-gray-500 max-w-xs mx-auto">Le système de versioning automatique n'a pas encore capturé d'archives pour cette instance.</p>
            </div>
        <% } else { %>
            <div class="grid grid-cols-1 gap-4">
                <% backups.forEach(backup => { %>
                    <div class="glass p-8 rounded-[2.5rem] border border-white/5 hover:border-gold/20 transition-all flex flex-col md:flex-row md:items-center justify-between group relative overflow-hidden">
                        <div class="absolute -top-10 -left-10 w-32 h-32 bg-gold/3 rounded-full blur-2xl group-hover:bg-gold/10 transition-all duration-700"></div>
                        
                        <div class="flex items-center space-x-6 relative z-10">
                            <div class="w-12 h-12 glass rounded-2xl flex items-center justify-center text-gold group-hover:scale-110 transition-transform">
                                <span class="text-xs font-black">v<%= backup.version %></span>
                            </div>
                            <div>
                                <h4 class="text-white font-bold tracking-tight">Instantané de compilation</h4>
                                <div class="flex items-center mt-1 space-x-4">
                                    <span class="text-[9px] font-black text-gray-500 uppercase tracking-widest flex items-center">
                                        <i data-lucide="calendar" class="w-3 h-3 mr-2"></i>
                                        <%= new Date(backup.createdAt).toLocaleString('fr-FR', {day: '2-digit', month: 'short', year: 'numeric'}) %>
                                    </span>
                                    <span class="text-[9px] font-black text-gray-500 uppercase tracking-widest flex items-center">
                                        <i data-lucide="clock" class="w-3 h-3 mr-2"></i>
                                        <%= new Date(backup.createdAt).toLocaleString('fr-FR', {hour: '2-digit', minute: '2-digit'}) %>
                                    </span>
                                </div>
                            </div>
                        </div>

                        <div class="flex items-center space-x-4 mt-6 md:mt-0 relative z-10">
                            <form action="/bots/<%= bot.id %>/restore/<%= backup.id %>" method="POST" onsubmit="return confirm('Attention : Cette action écrasera la configuration actuelle par la version v<%= backup.version %>. Continuer ?')">
                                <button type="submit" class="bg-gold/10 text-gold font-black px-6 py-3 rounded-xl text-[10px] uppercase tracking-widest border border-gold/10 hover:bg-gold hover:text-dark transition-all flex items-center group/btn">
                                    <i data-lucide="rotate-ccw" class="w-3.5 h-3.5 mr-2 group-hover/btn:rotate-[-45deg] transition-transform"></i>
                                    Restaurer
                                </button>
                            </form>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>
</div>
