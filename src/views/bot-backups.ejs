<div class="max-w-5xl mx-auto py-10 space-y-10">
    <div class="flex items-center justify-between">
        <div class="flex items-center space-x-4">
            <a href="/dashboard" class="w-12 h-12 bg-white/5 rounded-2xl flex items-center justify-center text-gray-400 hover:text-white border border-white/5 transition-all">
                <i data-lucide="arrow-left"></i>
            </a>
            <div>
                <h2 class="text-3xl font-bold text-white">Sauvegardes : <%= bot.name %></h2>
                <p class="text-gray-500">Gérez les versions précédentes de la configuration de votre bot.</p>
            </div>
        </div>
        <div class="px-5 py-2 bg-gold/10 border border-gold/20 rounded-2xl flex items-center space-x-2">
            <i data-lucide="shield" class="w-4 h-4 text-gold"></i>
            <span class="text-xs font-bold text-gold uppercase tracking-widest">Protection Active</span>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        <!-- Dashboard Summary -->
        <div class="lg:col-span-1 space-y-6">
            <div class="bg-dark-card border border-white/5 p-8 rounded-[2.5rem] shadow-2xl">
                <h3 class="text-white font-bold mb-6">Résumé Actuel</h3>
                <div class="space-y-4">
                    <div class="bg-white/5 p-4 rounded-2xl">
                        <p class="text-[10px] text-gray-500 uppercase font-black mb-1">Type de Bot</p>
                        <p class="text-white font-mono"><%= bot.type %></p>
                    </div>
                    <div class="bg-white/5 p-4 rounded-2xl">
                        <p class="text-[10px] text-gray-500 uppercase font-black mb-1">Préfixe Actuel</p>
                        <p class="text-gold font-mono text-xl"><%= bot.prefix %></p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Backups List -->
        <div class="lg:col-span-2 space-y-6">
            <div class="bg-dark-card border border-white/5 rounded-[2.5rem] overflow-hidden shadow-2xl">
                <div class="px-8 py-6 border-b border-white/5 bg-white/[0.02]">
                    <h3 class="text-lg font-bold text-white">Historique de Configuration</h3>
                </div>
                
                <div class="divide-y divide-white/[0.05]">
                    <% if (backups.length === 0) { %>
                        <div class="p-20 text-center">
                            <p class="text-gray-500">Aucune sauvegarde disponible pour ce bot.</p>
                        </div>
                    <% } else { %>
                        <% backups.forEach(backup => { %>
                            <div class="p-8 flex items-center justify-between group hover:bg-white/[0.01] transition-colors">
                                <div class="flex items-center space-x-5">
                                    <div class="w-12 h-12 bg-white/5 rounded-2xl flex items-center justify-center text-gray-500 group-hover:bg-gold/10 group-hover:text-gold transition-all">
                                        <i data-lucide="database"></i>
                                    </div>
                                    <div>
                                        <h4 class="text-white font-bold">Version v<%= backup.version %></h4>
                                        <p class="text-xs text-gray-500"><%= new Date(backup.createdAt).toLocaleString('fr-FR') %></p>
                                    </div>
                                </div>
                                <div class="flex items-center space-x-3">
                                    <button @click="alert('Contenu : ' + '<%= backup.config.replace(/'/g, "\\'") %>')" class="p-3 text-gray-500 hover:text-white transition-colors" title="Aperçu JSON">
                                        <i data-lucide="eye" class="w-5 h-5"></i>
                                    </button>
                                    <form action="/bots/<%= bot.id %>/restore/<%= backup.id %>" method="POST" onsubmit="return confirm('Voulez-vous vraiment restaurer cette version ? La configuration actuelle sera écrasée.')">
                                        <button type="submit" class="bg-gold/10 text-gold hover:bg-gold hover:text-dark px-5 py-2.5 rounded-xl text-xs font-bold transition-all border border-gold/10">
                                            Restaurer
                                        </button>
                                    </form>
                                </div>
                            </div>
                        <% }) %>
                    <% } %>
                </div>
                
                <div class="p-6 bg-white/[0.02] text-center border-t border-white/5">
                    <p class="text-[10px] text-gray-600 font-bold uppercase tracking-widest italic">Les 5 dernières versions sont conservées automatiquement.</p>
                </div>
            </div>
        </div>
    </div>
</div>
