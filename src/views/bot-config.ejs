<div class="max-w-5xl mx-auto py-8">
    <div class="mb-12 flex flex-col md:flex-row md:items-end justify-between gap-6 px-2">
        <div>
            <div class="flex items-center space-x-3 mb-3">
                <div class="w-10 h-10 glass rounded-xl flex items-center justify-center text-gold">
                    <i data-lucide="settings-2" class="w-5 h-5"></i>
                </div>
                <span class="text-[10px] font-black text-gray-500 uppercase tracking-[0.3em]">Module de Conception</span>
            </div>
            <h2 class="text-4xl font-black text-white tracking-tight">Configuration de <span class="gold-gradient-text italic">l'Instance</span></h2>
            <p class="text-gray-500 font-medium mt-1">Définissez les paramètres structurels de votre future architecture Baileys.</p>
        </div>
        <a href="/dashboard" class="glass px-6 py-3 rounded-xl text-gray-400 hover:text-white flex items-center text-[10px] font-black uppercase tracking-widest transition-all hover:border-white/20">
            <i data-lucide="arrow-left" class="w-3.5 h-3.5 mr-2"></i>
            Annuler
        </a>
    </div>

    <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
        <div class="bg-red-500/10 border border-red-500/20 text-red-500 p-6 rounded-[2rem] mb-10 text-sm font-bold animate-shake">
            <div class="flex items-center mb-4">
                <i data-lucide="shield-alert" class="w-5 h-5 mr-3"></i>
                <span>Erreurs de validation détectées :</span>
            </div>
            <ul class="space-y-1 ml-8 list-disc">
                <% errors.forEach(error => { %>
                    <li><%= typeof error === 'string' ? error : error.message %></li>
                <% }) %>
            </ul>
        </div>
    <% } %>

    <form action="/api/bots/generate" method="POST" class="space-y-10">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
            <!-- Section: Identité -->
            <div class="glass p-10 rounded-[3rem] border border-white/5 space-y-8 relative overflow-hidden">
                <div class="absolute -top-10 -right-10 w-32 h-32 bg-gold/5 rounded-full blur-2xl"></div>
                
                <h3 class="text-lg font-black text-white flex items-center uppercase tracking-widest">
                    <i data-lucide="fingerprint" class="w-5 h-5 mr-3 text-gold"></i>
                    Identité Système
                </h3>
                
                <div class="space-y-6">
                    <div class="space-y-2">
                        <label class="text-[10px] font-black text-gray-500 uppercase tracking-widest ml-1">Désignation du Bot</label>
                        <input type="text" name="name" required value="<%= data.name || '' %>" class="w-full bg-black/20 border border-white/5 rounded-2xl py-4 px-5 text-white focus:outline-none transition-all placeholder:text-gray-700 font-medium border-l-gold/30 border-l-2" placeholder="Ex: Kurona MD Platinium">
                    </div>

                    <div class="grid grid-cols-2 gap-6">
                        <div class="space-y-2">
                            <label class="text-[10px] font-black text-gray-500 uppercase tracking-widest ml-1">Template Core</label>
                            <div class="relative">
                                <select name="type" class="w-full bg-black/20 border border-white/5 rounded-2xl py-4 px-5 text-white focus:outline-none transition-all appearance-none cursor-pointer font-bold text-xs uppercase tracking-widest">
                                    <option value="MDX" <%= data.type === 'MDX' ? 'selected' : '' %>>Standard MDX</option>
                                    <option value="East" <%= data.type === 'East' ? 'selected' : '' %>>East Light</option>
                                    <option value="Custom" <%= data.type === 'Custom' ? 'selected' : '' %>>Full Custom</option>
                                </select>
                                <i data-lucide="chevron-down" class="absolute right-4 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-600 pointer-events-none"></i>
                            </div>
                        </div>

                        <div class="space-y-2">
                            <label class="text-[10px] font-black text-gray-500 uppercase tracking-widest ml-1">Préfixe Actif</label>
                            <input type="text" name="prefix" required maxlength="1" value="<%= data.prefix || '.' %>" class="w-full bg-black/20 border border-white/5 rounded-2xl py-4 px-5 text-gold focus:outline-none transition-all font-black text-center text-xl placeholder:text-gray-800" placeholder=".">
                        </div>
                    </div>
                </div>
            </div>

            <!-- Section: Propriétaire -->
            <div class="glass p-10 rounded-[3rem] border border-white/5 space-y-8 relative overflow-hidden">
                <div class="absolute -bottom-10 -left-10 w-32 h-32 bg-gold/5 rounded-full blur-2xl"></div>

                <h3 class="text-lg font-black text-white flex items-center uppercase tracking-widest">
                    <i data-lucide="crown" class="w-5 h-5 mr-3 text-gold"></i>
                    Authority Protocol
                </h3>

                <div class="space-y-6">
                    <div class="space-y-2">
                        <label class="text-[10px] font-black text-gray-500 uppercase tracking-widest ml-1">Identité Owner</label>
                        <input type="text" name="ownerName" required value="<%= data.ownerName || '' %>" class="w-full bg-black/20 border border-white/5 rounded-2xl py-4 px-5 text-white focus:outline-none transition-all placeholder:text-gray-700 font-medium" placeholder="Votre nom d'élite">
                    </div>

                    <div class="space-y-2">
                        <label class="text-[10px] font-black text-gray-500 uppercase tracking-widest ml-1">Numéro Global (avec indicatif)</label>
                        <div class="relative">
                            <i data-lucide="phone" class="absolute left-5 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-600"></i>
                            <input type="text" name="ownerNumber" required value="<%= data.ownerNumber || '' %>" class="w-full bg-black/20 border border-white/5 rounded-2xl py-4 pl-14 pr-5 text-white font-mono text-sm focus:outline-none transition-all placeholder:text-gray-700 font-bold" placeholder="33612345678">
                        </div>
                        <p class="text-[9px] text-gray-600 mt-2 font-bold uppercase tracking-wider ml-1 italic">Format international sans le caractère "+"</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Section: Modules -->
        <div class="glass p-12 rounded-[4rem] border border-white/5 space-y-10 relative overflow-hidden">
            <div class="flex items-center justify-between border-b border-white/5 pb-8">
                <div>
                    <h3 class="text-2xl font-black text-white uppercase tracking-tighter">Capacités <span class="text-gold">Opérationnelles</span></h3>
                    <p class="text-[10px] font-bold text-gray-600 uppercase tracking-widest mt-1">Sélectionnez les algorithmes à injecter dans l'architecture</p>
                </div>
                <div class="hidden md:flex space-x-2">
                    <span class="w-2 h-2 rounded-full bg-gold/20"></span>
                    <span class="w-2 h-2 rounded-full bg-gold/50"></span>
                    <span class="w-2 h-2 rounded-full bg-gold"></span>
                </div>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                <!-- Module AI -->
                <label class="relative group cursor-pointer">
                    <input type="checkbox" name="modules" value="ai" class="peer sr-only" checked>
                    <div class="h-full p-8 rounded-[2.5rem] bg-black/20 border border-white/5 peer-checked:border-gold peer-checked:bg-gold/5 transition-all duration-500 group-hover:scale-[1.02]">
                        <div class="w-12 h-12 bg-white/5 rounded-2xl flex items-center justify-center mb-6 text-gray-600 peer-checked:text-gold peer-checked:bg-gold/10 transition-all border border-transparent peer-checked:border-gold/20">
                            <i data-lucide="cpu" class="w-6 h-6"></i>
                        </div>
                        <h4 class="text-white font-black text-xs uppercase tracking-widest mb-2 group-hover:text-gold transition-colors">Intelligence</h4>
                        <p class="text-[10px] text-gray-600 font-medium leading-relaxed group-hover:text-gray-500 transition-colors">Intégration native de l'IA Gemini pour des interactions cognitives.</p>
                    </div>
                </label>

                <!-- Module Downloader -->
                <label class="relative group cursor-pointer">
                    <input type="checkbox" name="modules" value="downloader" class="peer sr-only" checked>
                    <div class="h-full p-8 rounded-[2.5rem] bg-black/20 border border-white/5 peer-checked:border-gold peer-checked:bg-gold/5 transition-all duration-500 group-hover:scale-[1.02]">
                        <div class="w-12 h-12 bg-white/5 rounded-2xl flex items-center justify-center mb-6 text-gray-600 peer-checked:text-gold peer-checked:bg-gold/10 transition-all border border-transparent peer-checked:border-gold/20">
                            <i data-lucide="download-cloud" class="w-6 h-6"></i>
                        </div>
                        <h4 class="text-white font-black text-xs uppercase tracking-widest mb-2 group-hover:text-gold transition-colors">Extraction</h4>
                        <p class="text-[10px] text-gray-600 font-medium leading-relaxed group-hover:text-gray-500 transition-colors">Algorithmes de récupération média multi-plateformes hautes performances.</p>
                    </div>
                </label>

                <!-- Module Tools -->
                <label class="relative group cursor-pointer">
                    <input type="checkbox" name="modules" value="tools" class="peer sr-only" checked>
                    <div class="h-full p-8 rounded-[2.5rem] bg-black/20 border border-white/5 peer-checked:border-gold peer-checked:bg-gold/5 transition-all duration-500 group-hover:scale-[1.02]">
                        <div class="w-12 h-12 bg-white/5 rounded-2xl flex items-center justify-center mb-6 text-gray-600 peer-checked:text-gold peer-checked:bg-gold/10 transition-all border border-transparent peer-checked:border-gold/20">
                            <i data-lucide="layout-grid" class="w-6 h-6"></i>
                        </div>
                        <h4 class="text-white font-black text-xs uppercase tracking-widest mb-2 group-hover:text-gold transition-colors">Utilitaires</h4>
                        <p class="text-[10px] text-gray-600 font-medium leading-relaxed group-hover:text-gray-500 transition-colors">Suite complète d'outils de conversion et de traitement de données.</p>
                    </div>
                </label>

                <!-- Module Group -->
                <label class="relative group cursor-pointer">
                    <input type="checkbox" name="modules" value="group" class="peer sr-only" checked>
                    <div class="h-full p-8 rounded-[2.5rem] bg-black/20 border border-white/5 peer-checked:border-gold peer-checked:bg-gold/5 transition-all duration-500 group-hover:scale-[1.02]">
                        <div class="w-12 h-12 bg-white/5 rounded-2xl flex items-center justify-center mb-6 text-gray-600 peer-checked:text-gold peer-checked:bg-gold/10 transition-all border border-transparent peer-checked:border-gold/20">
                            <i data-lucide="shield-check" class="w-6 h-6"></i>
                        </div>
                        <h4 class="text-white font-black text-xs uppercase tracking-widest mb-2 group-hover:text-gold transition-colors">Modération</h4>
                        <p class="text-[10px] text-gray-600 font-medium leading-relaxed group-hover:text-gray-500 transition-colors">Protocoles de sécurité avancés et gestion de communauté automatisée.</p>
                    </div>
                </label>
            </div>

            <div class="pt-16 flex flex-col items-center">
                <button type="submit" class="bg-gold text-dark font-black px-16 py-6 rounded-[2.5rem] text-xl hover:scale-105 active:scale-95 transition-all shadow-[0_20px_60px_rgba(212,163,115,0.4)] flex items-center space-x-4 uppercase tracking-tighter border border-gold-light/30 group">
                    <i data-lucide="box" class="w-7 h-7 group-hover:rotate-12 transition-transform"></i>
                    <span>Compilation Phoenix</span>
                </button>
                <div class="mt-8 flex items-center space-x-6">
                    <div class="flex items-center">
                        <i data-lucide="check-circle-2" class="w-3 h-3 text-gold mr-2"></i>
                        <span class="text-[9px] font-black text-gray-600 uppercase tracking-widest">Code Signé</span>
                    </div>
                    <div class="flex items-center">
                        <i data-lucide="check-circle-2" class="w-3 h-3 text-gold mr-2"></i>
                        <span class="text-[9px] font-black text-gray-600 uppercase tracking-widest">Optimisé V8</span>
                    </div>
                    <div class="flex items-center">
                        <i data-lucide="check-circle-2" class="w-3 h-3 text-gold mr-2"></i>
                        <span class="text-[9px] font-black text-gray-600 uppercase tracking-widest">Prêt au Déploiement</span>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>
