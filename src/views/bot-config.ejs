<div class="max-w-4xl mx-auto py-6">
    <div class="mb-10 flex items-center justify-between">
        <div>
            <h2 class="text-3xl font-bold text-white mb-2">Configurer votre Bot</h2>
            <p class="text-gray-500">Personnalisez votre assistant selon vos besoins avant de le générer.</p>
        </div>
        <a href="/dashboard" class="text-gray-500 hover:text-white flex items-center text-sm font-medium transition-colors">
            <i data-lucide="arrow-left" class="w-4 h-4 mr-2"></i>
            Retour
        </a>
    </div>

    <% if (errors && errors.length > 0) { %>
        <div class="bg-red-400/10 border border-red-400/20 text-red-400 p-4 rounded-2xl mb-8 text-sm">
            <ul class="list-disc list-inside">
                <% errors.forEach(error => { %>
                    <li><%= typeof error === 'string' ? error : error.message %></li>
                <% }) %>
            </ul>
        </div>
    <% } %>

    <form action="/api/bots/generate" method="POST" class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <!-- Section: Identité -->
        <div class="bg-dark-card border border-white/5 p-8 rounded-[2.5rem] space-y-6">
            <h3 class="text-white font-bold text-lg border-b border-white/5 pb-4 mb-6">Identité du Bot</h3>
            
            <div class="space-y-2">
                <label class="text-sm font-medium text-gray-400 ml-1">Nom du Bot</label>
                <input type="text" name="name" required value="<%= data.name || '' %>" class="w-full bg-[#121417] border border-white/10 rounded-2xl py-3.5 px-4 text-white focus:border-gold outline-none transition-all" placeholder="Ex: KuronaBot MD">
            </div>

            <div class="space-y-2">
                <label class="text-sm font-medium text-gray-400 ml-1">Type de Template</label>
                <select name="type" class="w-full bg-[#121417] border border-white/10 rounded-2xl py-3.5 px-4 text-white focus:border-gold outline-none transition-all appearance-none cursor-pointer">
                    <option value="MDX" <%= data.type === 'MDX' ? 'selected' : '' %>>MDX (Standard stable)</option>
                    <option value="East" <%= data.type === 'East' ? 'selected' : '' %>>East (Rapide & Léger)</option>
                    <option value="Custom" <%= data.type === 'Custom' ? 'selected' : '' %>>Custom (Avancé)</option>
                </select>
            </div>

            <div class="space-y-2">
                <label class="text-sm font-medium text-gray-400 ml-1">Préfixe des commandes</label>
                <input type="text" name="prefix" required maxlength="1" value="<%= data.prefix || '.' %>" class="w-full bg-[#121417] border border-white/10 rounded-2xl py-3.5 px-4 text-white focus:border-gold outline-none transition-all font-mono text-center text-xl" placeholder=".">
            </div>
        </div>

        <!-- Section: Propriétaire -->
        <div class="bg-dark-card border border-white/5 p-8 rounded-[2.5rem] space-y-6">
            <h3 class="text-white font-bold text-lg border-b border-white/5 pb-4 mb-6">Configuration Propriétaire</h3>

            <div class="space-y-2">
                <label class="text-sm font-medium text-gray-400 ml-1">Nom du propriétaire</label>
                <input type="text" name="ownerName" required value="<%= data.ownerName || '' %>" class="w-full bg-[#121417] border border-white/10 rounded-2xl py-3.5 px-4 text-white focus:border-gold outline-none transition-all" placeholder="Votre nom">
            </div>

            <div class="space-y-2">
                <label class="text-sm font-medium text-gray-400 ml-1">Numéro du propriétaire (sans +)</label>
                <div class="relative">
                    <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-500 font-mono">+</span>
                    <input type="text" name="ownerNumber" required value="<%= data.ownerNumber || '' %>" class="w-full bg-[#121417] border border-white/10 rounded-2xl py-3.5 pl-8 pr-4 text-white font-mono focus:border-gold outline-none transition-all" placeholder="33612345678">
                </div>
                <p class="text-[10px] text-gray-600 mt-1 italic">Entrez votre numéro WhatsApp complet avec l'indicatif pays.</p>
            </div>
        </div>

        <!-- Section: Modules -->
        <div class="lg:col-span-2 bg-dark-card border border-white/5 p-8 rounded-[3rem] space-y-8">
            <h3 class="text-white font-bold text-lg border-b border-white/5 pb-4 mb-2">Activer les modules optionnels</h3>
            
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                <!-- Module AI -->
                <label class="relative group cursor-pointer">
                    <input type="checkbox" name="modules" value="ai" class="peer sr-only" checked>
                    <div class="p-6 rounded-3xl bg-[#121417] border-2 border-white/5 peer-checked:border-gold peer-checked:bg-gold/5 transition-all duration-300">
                        <div class="w-10 h-10 bg-white/5 rounded-xl flex items-center justify-center mb-4 text-gray-500 peer-checked:text-gold peer-checked:bg-gold/10 transition-colors">
                            <i data-lucide="cpu" class="w-5 h-5"></i>
                        </div>
                        <h4 class="text-white font-bold text-sm mb-1">Intelligence Artificielle</h4>
                        <p class="text-[10px] text-gray-600 line-clamp-2">Intégrez Gemini pour des conversations fluides.</p>
                    </div>
                </label>

                <!-- Module Downloader -->
                <label class="relative group cursor-pointer">
                    <input type="checkbox" name="modules" value="downloader" class="peer sr-only" checked>
                    <div class="p-6 rounded-3xl bg-[#121417] border-2 border-white/5 peer-checked:border-gold peer-checked:bg-gold/5 transition-all duration-300">
                        <div class="w-10 h-10 bg-white/5 rounded-xl flex items-center justify-center mb-4 text-gray-500 transition-colors">
                            <i data-lucide="download" class="w-5 h-5"></i>
                        </div>
                        <h4 class="text-white font-bold text-sm mb-1">Téléchargements</h4>
                        <p class="text-[10px] text-gray-600 line-clamp-2">Téléchargez du contenu d'Instagram, YouTube, etc.</p>
                    </div>
                </label>

                <!-- Module Tools -->
                <label class="relative group cursor-pointer">
                    <input type="checkbox" name="modules" value="tools" class="peer sr-only" checked>
                    <div class="p-6 rounded-3xl bg-[#121417] border-2 border-white/5 peer-checked:border-gold peer-checked:bg-gold/5 transition-all duration-300">
                        <div class="w-10 h-10 bg-white/5 rounded-xl flex items-center justify-center mb-4 text-gray-500 transition-colors">
                            <i data-lucide="wrench" class="w-5 h-5"></i>
                        </div>
                        <h4 class="text-white font-bold text-sm mb-1">Outils Utilitaires</h4>
                        <p class="text-[10px] text-gray-600 line-clamp-2">Recherche, traduction, convertisseurs, etc.</p>
                    </div>
                </label>

                <!-- Module Group -->
                <label class="relative group cursor-pointer">
                    <input type="checkbox" name="modules" value="group" class="peer sr-only" checked>
                    <div class="p-6 rounded-3xl bg-[#121417] border-2 border-white/5 peer-checked:border-gold peer-checked:bg-gold/5 transition-all duration-300">
                        <div class="w-10 h-10 bg-white/5 rounded-xl flex items-center justify-center mb-4 text-gray-500 transition-colors">
                            <i data-lucide="users" class="w-5 h-5"></i>
                        </div>
                        <h4 class="text-white font-bold text-sm mb-1">Gestion de Groupes</h4>
                        <p class="text-[10px] text-gray-600 line-clamp-2">Antilink, bienvenue, kick, promote, etc.</p>
                    </div>
                </label>
            </div>

            <div class="pt-10 flex flex-col items-center">
                <button type="submit" class="bg-gold text-dark font-black px-12 py-5 rounded-[2rem] text-xl hover:scale-105 active:scale-95 transition-all shadow-2xl shadow-gold/30 flex items-center space-x-3">
                    <i data-lucide="package" class="w-6 h-6"></i>
                    <span>Générer mon Bot (ZIP)</span>
                </button>
                <p class="text-gray-500 text-xs mt-6 italic">En générant le bot, vous acceptez nos conditions d'utilisation.</p>
            </div>
        </div>
    </form>
</div>
