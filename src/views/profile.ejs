<div class="max-w-5xl mx-auto py-8">
    <div class="mb-12 flex items-center justify-between px-2">
        <div>
            <div class="flex items-center space-x-3 mb-3">
                <div class="w-10 h-10 glass rounded-xl flex items-center justify-center text-gold">
                    <i data-lucide="user-check" class="w-5 h-5"></i>
                </div>
                <span class="text-[10px] font-black text-gray-500 uppercase tracking-[0.3em]">Centre de Profil Platinium</span>
            </div>
            <h2 class="text-4xl font-black text-white tracking-tight">Gestion du <span class="gold-gradient-text italic">Compte</span></h2>
            <p class="text-gray-500 font-medium mt-1">Supervisez votre identité numérique et vos paramètres de sécurité.</p>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        <!-- Dashboard Identité -->
        <div class="lg:col-span-1 space-y-6">
            <div class="glass p-10 rounded-[3.5rem] border border-white/5 flex flex-col items-center text-center relative overflow-hidden group">
                <div class="absolute -top-10 -right-10 w-32 h-32 bg-gold/5 rounded-full blur-2xl group-hover:bg-gold/10 transition-all duration-700"></div>
                
                <div class="w-28 h-28 rounded-[2.5rem] bg-gold/10 border-2 border-gold/30 flex items-center justify-center text-gold mb-8 relative group-hover:scale-105 transition-transform duration-500">
                    <i data-lucide="user" class="w-12 h-12"></i>
                    <div class="absolute bottom-[-4px] right-[-4px] w-8 h-8 bg-green-500 border-4 border-[#0B0E14] rounded-full shadow-[0_0_15px_rgba(34,197,94,0.4)]"></div>
                </div>
                
                <h3 class="text-2xl font-black text-white tracking-tight mb-1"><%= user.username %></h3>
                <p class="text-gray-600 text-xs font-black uppercase tracking-widest"><%= user.email %></p>
                
                <div class="w-full h-px bg-white/5 my-8"></div>
                
                <div class="grid grid-cols-2 gap-4 w-full">
                    <div class="glass bg-white/5 p-4 rounded-2xl border border-white/5">
                        <p class="text-[9px] text-gray-500 uppercase font-black tracking-widest mb-2">Architectures</p>
                        <p class="text-white font-black text-xl">--</p>
                    </div>
                    <div class="glass bg-white/5 p-4 rounded-2xl border border-white/5">
                        <p class="text-[9px] text-gray-500 uppercase font-black tracking-widest mb-2">Privilèges</p>
                        <p class="text-gold font-black uppercase text-[10px] tracking-widest"><%= user.role %></p>
                    </div>
                </div>

                <div class="mt-10 px-4 py-3 bg-white/5 rounded-2xl border border-white/5 w-full flex items-center justify-center space-x-3">
                    <i data-lucide="shield-check" class="w-4 h-4 text-gold"></i>
                    <span class="text-[9px] font-black text-gray-400 uppercase tracking-widest">Compte Vérifié</span>
                </div>
            </div>
        </div>

        <!-- Security Terminal -->
        <div class="lg:col-span-2">
            <div class="glass p-12 rounded-[3.5rem] border border-white/5 shadow-[0_30px_80px_rgba(0,0,0,0.4)] relative overflow-hidden">
                <div class="absolute -bottom-20 -left-20 w-40 h-40 bg-gold/5 rounded-full blur-3xl"></div>

                <h3 class="text-xl font-black text-white mb-10 flex items-center uppercase tracking-wider">
                    <i data-lucide="key" class="w-6 h-6 mr-4 text-gold"></i>
                    Séquence de Sécurité
                </h3>

                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="bg-red-500/10 border border-red-500/20 text-red-500 p-6 rounded-2xl mb-10 text-sm font-bold flex items-center animate-shake">
                        <i data-lucide="alert-triangle" class="w-5 h-5 mr-4"></i>
                        <%= error %>
                    </div>
                <% } %>

                <% if (typeof success !== 'undefined' && success) { %>
                    <div class="bg-green-500/10 border border-green-500/20 text-green-500 p-6 rounded-2xl mb-10 text-sm font-bold flex items-center">
                        <i data-lucide="check-circle" class="w-5 h-5 mr-4"></i>
                        <%= success %>
                    </div>
                <% } %>

                <form action="/profile" method="POST" class="space-y-8">
                    <div class="space-y-2">
                        <label class="text-[10px] font-black text-gray-500 uppercase tracking-widest ml-1">Clé d'Accès Actuelle</label>
                        <div class="relative">
                            <i data-lucide="lock" class="absolute left-5 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-600"></i>
                            <input type="password" name="currentPassword" required class="w-full bg-black/20 border border-white/5 rounded-2xl py-4 pl-14 pr-5 text-white focus:outline-none transition-all placeholder:text-gray-800 font-medium" placeholder="••••••••••••">
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        <div class="space-y-2">
                            <label class="text-[10px] font-black text-gray-500 uppercase tracking-widest ml-1">Nouvelle Clé</label>
                            <input type="password" name="newPassword" required class="w-full bg-black/20 border border-white/5 rounded-2xl py-4 px-5 text-white focus:outline-none transition-all placeholder:text-gray-800 font-medium" placeholder="Minimum 8 car.">
                        </div>
                        <div class="space-y-2">
                            <label class="text-[10px] font-black text-gray-500 uppercase tracking-widest ml-1">Validation de Clé</label>
                            <input type="password" name="confirmPassword" required class="w-full bg-black/20 border border-white/5 rounded-2xl py-4 px-5 text-white focus:outline-none transition-all placeholder:text-gray-800 font-medium" placeholder="Répéter la clé">
                        </div>
                    </div>

                    <div class="pt-6">
                        <button type="submit" class="bg-gold text-dark font-black px-12 py-5 rounded-2xl hover:scale-105 active:scale-95 transition-all shadow-2xl shadow-gold/20 uppercase text-xs tracking-widest border border-gold-light/20">
                            Mettre à jour le protocole
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
