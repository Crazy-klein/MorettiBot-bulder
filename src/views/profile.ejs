<div class="max-w-4xl mx-auto py-6">
    <div class="mb-10">
        <h2 class="text-3xl font-bold text-white mb-2">Mon Profil</h2>
        <p class="text-gray-500">Gérez vos informations personnelles et la sécurité de votre compte.</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        <!-- Infos -->
        <div class="lg:col-span-1 space-y-6">
            <div class="bg-dark-card border border-white/5 p-8 rounded-[2.5rem] flex flex-col items-center text-center">
                <div class="w-24 h-24 rounded-full bg-gold/10 border-2 border-gold/30 flex items-center justify-center text-gold mb-6 relative">
                    <i data-lucide="user" class="w-10 h-10"></i>
                    <div class="absolute bottom-0 right-0 w-6 h-6 bg-green-500 border-4 border-dark-card rounded-full"></div>
                </div>
                <h3 class="text-xl font-bold text-white"><%= user.username %></h3>
                <p class="text-gray-500 text-sm mb-6"><%= user.email %></p>
                
                <div class="w-full h-px bg-white/5 mb-6"></div>
                
                <div class="grid grid-cols-2 gap-4 w-full">
                    <div class="bg-white/5 p-3 rounded-2xl">
                        <p class="text-[10px] text-gray-500 uppercase font-bold mb-1">Bots</p>
                        <p class="text-white font-bold">12</p>
                    </div>
                    <div class="bg-white/5 p-3 rounded-2xl">
                        <p class="text-[10px] text-gray-500 uppercase font-bold mb-1">Rôle</p>
                        <p class="text-gold font-bold uppercase text-[10px]"><%= user.role %></p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Security Form -->
        <div class="lg:col-span-2">
            <div class="bg-dark-card border border-white/5 p-8 md:p-10 rounded-[2.5rem] shadow-2xl">
                <h3 class="text-xl font-bold text-white mb-8 flex items-center">
                    <i data-lucide="shield" class="w-5 h-5 mr-3 text-gold"></i>
                    Changer le mot de passe
                </h3>

                <% if (error) { %>
                    <div class="bg-red-400/10 border border-red-400/20 text-red-400 p-4 rounded-2xl mb-8 text-sm flex items-center">
                        <i data-lucide="alert-circle" class="w-4 h-4 mr-2"></i>
                        <%= error %>
                    </div>
                <% } %>

                <% if (success) { %>
                    <div class="bg-green-400/10 border border-green-400/20 text-green-400 p-4 rounded-2xl mb-8 text-sm flex items-center">
                        <i data-lucide="check-circle" class="w-4 h-4 mr-2"></i>
                        <%= success %>
                    </div>
                <% } %>

                <form action="/profile" method="POST" class="space-y-6">
                    <div class="space-y-2">
                        <label class="text-sm font-medium text-gray-400 ml-1">Mot de passe actuel</label>
                        <input type="password" name="currentPassword" required class="w-full bg-[#121417] border border-white/10 rounded-2xl py-4 px-4 text-white focus:border-gold outline-none transition-all" placeholder="••••••••">
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="space-y-2">
                            <label class="text-sm font-medium text-gray-400 ml-1">Nouveau mot de passe</label>
                            <input type="password" name="newPassword" required class="w-full bg-[#121417] border border-white/10 rounded-2xl py-4 px-4 text-white focus:border-gold outline-none transition-all" placeholder="••••••••">
                        </div>
                        <div class="space-y-2">
                            <label class="text-sm font-medium text-gray-400 ml-1">Confirmer nouveau</label>
                            <input type="password" name="confirmPassword" required class="w-full bg-[#121417] border border-white/10 rounded-2xl py-4 px-4 text-white focus:border-gold outline-none transition-all" placeholder="••••••••">
                        </div>
                    </div>

                    <div class="pt-4">
                        <button type="submit" class="bg-gold text-dark font-bold px-8 py-4 rounded-2xl hover:scale-105 transition-all shadow-xl shadow-gold/20">
                            Mettre à jour le mot de passe
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
