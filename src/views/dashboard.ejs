<div class="space-y-12">
    <!-- Header Dashboard -->
    <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-8">
        <div>
            <div class="flex items-center space-x-3 mb-3">
                <span class="px-3 py-1 bg-gold/10 text-gold text-[9px] font-black uppercase tracking-widest rounded-full border border-gold/20">Accès Platinium</span>
                <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
                <span class="text-[9px] font-bold text-gray-500 uppercase tracking-widest">Serveurs Opérationnels</span>
            </div>
            <h2 class="text-4xl md:text-5xl font-black text-white tracking-tight">Bonjour, <span class="gold-gradient-text italic"><%= user.username %></span></h2>
            <p class="text-gray-500 font-medium mt-2">Votre écosystème d'automatisation est prêt pour de nouvelles performances.</p>
        </div>
        <div class="flex items-center space-x-4">
            <a href="/bots/new" class="bg-gold text-dark font-black px-10 py-5 rounded-2xl hover:scale-105 active:scale-95 transition-all shadow-2xl shadow-gold/20 uppercase text-xs tracking-widest border border-gold-light/20 flex items-center">
                <i data-lucide="plus" class="w-4 h-4 mr-3"></i>
                Nouveau Bot
            </a>
        </div>
    </div>

    <!-- Quick Stats -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="glass p-8 rounded-[2.5rem] border border-white/5 flex items-center space-x-6 group hover:border-gold/20 transition-all">
            <div class="w-14 h-14 bg-gold/10 rounded-2xl flex items-center justify-center text-gold group-hover:scale-110 transition-transform">
                <i data-lucide="bot" class="w-7 h-7"></i>
            </div>
            <div>
                <span class="text-4xl font-black text-white block leading-none"><%= bots.length %></span>
                <span class="text-[9px] font-bold text-gray-500 uppercase tracking-widest mt-1 block">Instances Actives</span>
            </div>
        </div>
        <div class="glass p-8 rounded-[2.5rem] border border-white/5 flex items-center space-x-6 group hover:border-gold/20 transition-all">
            <div class="w-14 h-14 bg-gold/10 rounded-2xl flex items-center justify-center text-gold group-hover:scale-110 transition-transform">
                <i data-lucide="zap" class="w-7 h-7"></i>
            </div>
            <div>
                <span class="text-4xl font-black text-white block leading-none">--</span>
                <span class="text-[9px] font-bold text-gray-500 uppercase tracking-widest mt-1 block">Commandes Éxécutées</span>
            </div>
        </div>
        <div class="glass p-8 rounded-[2.5rem] border border-white/5 flex items-center space-x-6 group hover:border-gold/20 transition-all">
            <div class="w-14 h-14 bg-gold/10 rounded-2xl flex items-center justify-center text-gold group-hover:scale-110 transition-transform">
                <i data-lucide="activity" class="w-7 h-7"></i>
            </div>
            <div>
                <span class="text-4xl font-black text-white block leading-none">99.9</span>
                <span class="text-[9px] font-bold text-gray-500 uppercase tracking-widest mt-1 block">% Fiabilité Système</span>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 pt-8">
        <!-- Main Column (Bots) -->
        <div class="lg:col-span-2 space-y-8">
            <div class="flex items-center justify-between px-2">
                <div class="flex items-center space-x-4">
                    <div class="w-1 h-8 bg-gold rounded-full"></div>
                    <h3 class="text-2xl font-black text-white tracking-tight uppercase">Mes Architectures</h3>
                </div>
                <div class="flex space-x-2">
                    <button class="w-10 h-10 glass rounded-xl flex items-center justify-center text-gray-500 hover:text-gold transition-colors">
                        <i data-lucide="filter" class="w-4 h-4"></i>
                    </button>
                    <button class="w-10 h-10 glass rounded-xl flex items-center justify-center text-gray-500 hover:text-gold transition-colors">
                        <i data-lucide="search" class="w-4 h-4"></i>
                    </button>
                </div>
            </div>

            <% if (bots.length === 0) { %>
                <div class="glass-dark border border-white/5 border-dashed rounded-[3rem] p-24 text-center group">
                    <div class="w-24 h-24 bg-white/5 rounded-[2rem] flex items-center justify-center mx-auto mb-8 text-gray-700 group-hover:scale-110 group-hover:bg-gold/5 transition-all duration-700">
                        <i data-lucide="cpu" class="w-12 h-12"></i>
                    </div>
                    <h4 class="text-2xl font-black text-white mb-3">Système Vierge</h4>
                    <p class="text-gray-500 max-w-sm mx-auto mb-10 font-medium">Démarrez le processus de création pour déployer votre première instance WhatsApp.</p>
                    <a href="/bots/new" class="inline-flex items-center space-x-3 text-gold font-black uppercase tracking-widest text-xs hover:tracking-[0.2em] transition-all">
                        <span>Lancer l'Initialisation</span>
                        <i data-lucide="arrow-right" class="w-4 h-4"></i>
                    </a>
                </div>
            <% } else { %>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <% bots.forEach(bot => { %>
                        <%- include('partials/bot-card', { bot }) %>
                    <% }) %>
                </div>
            <% } %>
        </div>

        <!-- Sidebar Column -->
        <div class="space-y-10">
            <!-- Activity Feed -->
            <div class="glass p-10 rounded-[3rem] relative overflow-hidden">
                <!-- Decor -->
                <div class="absolute -top-10 -right-10 w-32 h-32 bg-gold/5 rounded-full blur-2xl"></div>

                <h3 class="text-xl font-black text-white mb-10 flex items-center uppercase tracking-wider">
                    <i data-lucide="bar-chart-3" class="w-5 h-5 mr-4 text-gold"></i>
                    Activités
                </h3>
                
                <div class="space-y-8">
                    <% if (logs.length === 0) { %>
                        <div class="py-12 text-center">
                            <i data-lucide="loader-2" class="w-8 h-8 text-white/5 animate-spin mx-auto mb-4"></i>
                            <p class="text-gray-700 text-xs font-bold uppercase tracking-widest">En attente de logs...</p>
                        </div>
                    <% } else { %>
                        <% logs.forEach(log => { %>
                            <div class="relative pl-8 pb-10 border-l border-white/10 last:pb-0">
                                <div class="absolute left-[-6px] top-0 w-3 h-3 bg-dark-sidebar border-2 border-gold rounded-full shadow-[0_0_15px_rgba(212,163,115,0.6)]"></div>
                                <div class="space-y-2">
                                    <p class="text-xs text-white/90 font-black uppercase tracking-wide leading-tight"><%= log.action %></p>
                                    <p class="text-[11px] text-gray-500 leading-relaxed"><%= log.details %></p>
                                    <p class="text-[9px] text-gold/60 font-black uppercase tracking-widest mt-2 flex items-center">
                                        <i data-lucide="clock" class="w-2.5 h-2.5 mr-1.5"></i>
                                        <%= new Date(log.createdAt).toLocaleString('fr-FR', {hour: '2-digit', minute: '2-digit'}) %>
                                    </p>
                                </div>
                            </div>
                        <% }) %>
                    <% } %>
                </div>
            </div>

            <!-- Support Card -->
            <div class="glass bg-gold text-dark p-10 rounded-[3rem] shadow-[0_15px_40px_rgba(212,163,115,0.3)] group cursor-pointer border-0">
                <div class="w-14 h-14 bg-dark/10 rounded-2xl flex items-center justify-center mb-10 group-hover:scale-110 transition-transform">
                    <i data-lucide="message-square" class="w-7 h-7"></i>
                </div>
                <h4 class="text-2xl font-black mb-4 leading-tight">Accédez au Concierge.</h4>
                <p class="text-dark/70 text-sm font-semibold mb-8 leading-relaxed">Notre équipe d'élite est disponible pour optimiser vos architectures.</p>
                <div class="flex items-center text-xs font-black uppercase tracking-widest">
                    <span>Rejoindre l'Elite</span>
                    <i data-lucide="chevron-right" class="w-4 h-4 ml-2 group-hover:translate-x-2 transition-transform"></i>
                </div>
            </div>
        </div>
    </div>
</div>
