# GEMINI_API_KEY: Requis pour les appels API Gemini AI si le module AI est utilisé.
GEMINI_API_KEY="VOTRE_CLE_ICI"

# Configuration SMTP (pour le mot de passe oublié)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="votre-email@gmail.com"
SMTP_PASS="votre-mot-de-passe-application"

# Sécurité Admin (Interface /admin)
# Pour sécuriser l'accès admin par défaut, vous pouvez configurer des variables ici
ADMIN_EMAIL="admin@kuronabot.com"

# Session Secrète
SESSION_SECRET="une-cle-secrete-tres-longue-et-aleatoire"

# URL de l'application
APP_URL="http://localhost:3000"
