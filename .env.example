# Configuration de l'application
APP_NAME=KuronaBot Builder
PORT=3000
NODE_ENV=development

# Sécurité
SESSION_SECRET=votre_secret_tres_long_et_aleatoire
ADMIN_KEY=votre_cle_admin_pour_certaines_routes

# Mailer (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre_email@gmail.com
SMTP_PASS=votre_mot_de_pass_application
SMTP_SECURE=false

# Logging
LOG_LEVEL=info
